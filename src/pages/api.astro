---
import Layout from '../layouts/MainLayout.astro';
export const prerender = true;
---
<Layout title="API Inspector | REST Endpoint & JSON Auditor | DataSecureTools">
  <div style="max-width: 1200px; margin: 40px auto; padding: 0 20px; font-family: 'Inter', sans-serif; color: #0f172a;">
    
    <div style="width: 100%; height: 90px; background: #ffffff; border: 1px dashed #cbd5e1; border-radius: 12px; margin-bottom: 30px; display: flex; align-items: center; justify-content: center; color: #94a3b8; font-size: 0.8rem; letter-spacing: 1px;">
      ADVERTISEMENT - GOOGLE ADSENSE LEADERBOARD
    </div>

    <div style="display: grid; grid-template-columns: 1fr 340px; gap: 40px; align-items: start;">
      
      <main>
        <div style="background: #ffffff; border-radius: 40px; padding: 60px; box-shadow: 0 10px 30px rgba(0,0,0,0.02); border: 1px solid #f1f5f9;">
          <header style="margin-bottom: 40px;">
            <span style="background: #f1f5f9; color: #475569; padding: 6px 14px; border-radius: 100px; font-size: 0.75rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.5px;">Developer Intelligence</span>
            <h1 style="font-size: 3rem; font-weight: 900; margin-top: 15px; letter-spacing: -1.5px; color: #0f172a;">API Inspector</h1>
            <p style="color: #64748b; font-size: 1.15rem; margin-top: 15px; line-height: 1.6;">Audit RESTful endpoints, validate JSON structures, and monitor real-time network response signals.</p>
          </header>

          <div style="background: #f8fafc; padding: 8px; border-radius: 24px; display: flex; border: 1px solid #e2e8f0; margin-bottom: 35px;">
            <input type="text" id="target" placeholder="Enter API URL (e.g. https://api.github.com)" style="flex: 1; padding: 18px 25px; border: none; background: transparent; outline: none; font-size: 1.1rem; color: #0f172a;" />
            <button id="runBtn" style="background: #0f172a; color: white; padding: 0 35px; border-radius: 18px; border: none; font-weight: 800; font-size: 0.95rem; cursor: pointer; text-transform: uppercase;">INSPECT</button>
          </div>

          <div id="results" style="display: none; animation: slideUp 0.6s ease-out;">
              <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 30px;">
                  <div style="background: #ffffff; padding: 30px; border-radius: 24px; border: 1px solid #f1f5f9; text-align: center;">
                      <span style="font-size: 0.7rem; font-weight: 800; color: #94a3b8; text-transform: uppercase;">HTTP Status</span>
                      <div id="v-status" style="font-size: 2.2rem; font-weight: 900; color: #10b981; margin-top: 8px;">200</div>
                  </div>
                  <div style="background: #ffffff; padding: 30px; border-radius: 24px; border: 1px solid #f1f5f9; text-align: center;">
                      <span style="font-size: 0.7rem; font-weight: 800; color: #94a3b8; text-transform: uppercase;">Latency</span>
                      <div id="v-time" style="font-size: 1.8rem; font-weight: 900; color: #0f172a; margin-top: 8px;">0ms</div>
                  </div>
              </div>

              <div style="background: #0f172a; border-radius: 24px; padding: 40px; border: 1px solid #334155;">
                <h4 style="color: white; margin-bottom: 20px; font-size: 1rem; font-weight: 800;">JSON Response Stream</h4>
                <pre id="v-json" style="font-family: 'Fira Code', monospace; color: #38bdf8; font-size: 0.85rem; line-height: 1.6; max-height: 400px; overflow-y: auto; white-space: pre-wrap; margin: 0;"></pre>
              </div>
          </div>
        </div>

        <article style="margin-top: 60px; line-height: 1.8; color: #475569;">
          <h2 style="color: #0f172a; font-size: 1.8rem; font-weight: 900; letter-spacing: -0.5px;">Mastering API Network Performance and JSON Data Integrity</h2>
          <p style="margin-top: 20px;">Auditing <strong>REST API</strong> endpoints is critical for maintaining high <strong>Technical SEO</strong> standards and application stability. Poorly structured <strong>JSON payloads</strong> or slow <strong>TTFB (Time to First Byte)</strong> can negatively impact your site's rendering cycle, leading to crawl errors in search engine bots. Our <strong>API Inspector</strong> provides a sandbox to validate status codes and audit nested data hiyerarşies in real-time.</p>
          
          

          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 40px; margin-top: 40px;">
            <div>
                <h3 style="font-size: 1.15rem; font-weight: 800; color: #0f172a; margin-bottom: 15px;">Data Type Validation</h3>
                <p style="font-size: 0.95rem; line-height: 1.7;">Verifying if your API returns the correct primitives (Strings, Integers, Booleans) prevents client-side crashes and ensures your frontend logic remains robust across different browser environments.</p>
            </div>
            <div>
                <h3 style="font-size: 1.15rem; font-weight: 800; color: #0f172a; margin-bottom: 15px;">Security & CORS Auditing</h3>
                <p style="font-size: 0.95rem; line-height: 1.7;">Properly configured <strong>CORS (Cross-Origin Resource Sharing)</strong> headers and <strong>SSL certificates</strong> are mandatory for secure data exchange. Use this inspector to verify server signatures and network handshakes.</p>
            </div>
          </div>
        </article>
      </main>

      <aside>
        <div style="width: 100%; height: 600px; background: #ffffff; border: 1px dashed #cbd5e1; border-radius: 24px; margin-bottom: 40px; display: flex; align-items: center; justify-content: center; color: #94a3b8; font-size: 0.8rem; text-align: center; padding: 20px;">
          ADSENSE SKYSCRAPER
        </div>

        <div style="background: #f8fafc; border-radius: 32px; padding: 30px; border: 1px solid #f1f5f9;">
            <h3 style="font-size: 1rem; font-weight: 900; color: #0f172a; margin-bottom: 25px;">Strategic Advice</h3>
            <div style="background: #ffffff; padding: 25px; border-radius: 20px; box-shadow: 0 4px 6px rgba(0,0,0,0.01); margin-bottom: 20px; border: 1px solid #f1f5f9;">
                <strong style="color: #4f46e5; display: block; margin-bottom: 10px; font-size: 0.85rem; font-weight: 800; text-transform: uppercase;">Error Handling</strong>
                <p style="font-size: 0.8rem; color: #64748b; line-height: 1.6;">Design APIs to return meaningful error messages in JSON format rather than plain HTML 404 pages for better debugging.</p>
            </div>
        </div>
      </aside>

    </div>
  </div>
</Layout>

<style> @keyframes slideUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } } </style>

<script>
  const btn = document.getElementById('runBtn');
  btn?.addEventListener('click', async () => {
    const url = (document.getElementById('target') as HTMLInputElement).value.trim();
    if(!url) return alert("Enter API URL");

    btn.innerText = "INSPECTING...";
    btn.disabled = true;

    const start = performance.now();

    try {
      const proxyUrl = `https://api.allorigins.win/get?url=${encodeURIComponent(url)}`;
      const response = await fetch(proxyUrl);
      const json = await response.json();
      const end = performance.now();
      
      const status = json.status?.http_code || 200;
      const data = json.contents ? JSON.parse(json.contents) : json;

      document.getElementById('v-status').innerText = status;
      document.getElementById('v-status').style.color = status < 400 ? "#10b981" : "#ef4444";
      document.getElementById('v-time').innerText = Math.round(end - start) + "ms";
      document.getElementById('v-json').innerText = JSON.stringify(data, null, 2);

      document.getElementById('results').style.display = "block";
    } catch (e) {
      document.getElementById('v-status').innerText = "BLOCKED";
      document.getElementById('v-status').style.color = "#f59e0b";
      document.getElementById('v-json').innerText = "// Direct inspection blocked by server CORS policy or invalid endpoint.";
      document.getElementById('results').style.display = "block";
    } finally {
      btn.innerText = "INSPECT";
      btn.disabled = false;
    }
  });
</script>