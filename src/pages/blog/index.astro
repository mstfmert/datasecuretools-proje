---
import Layout from '../../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';

// Yazıları koleksiyondan çek ve tarihe göre sırala
const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout title="Intelligence Feed | DataSecureTools">
  <main class="blog-list-container">
    <header class="blog-hero">
      <span class="blog-badge">Expert Insights</span>
      <h1>Intelligence <span class="gradient-text">Feed</span></h1>
      <p>Açık kaynak vizyonuyla siber güvenlik ve veri analitiği üzerine en güncel rehberler.</p>
    </header>

    <div class="blog-grid">
      {sortedPosts.length === 0 ? (
        <p class="no-posts">Henüz makale yayınlanmadı. Takipte kalın!</p>
      ) : (
        sortedPosts.map((post) => (
          <a href={`/blog/${post.id}`} class="post-card">
            <div class="post-meta">
              <span class="post-cat">Intelligence</span>
              <span class="post-date">{post.data.pubDate.toLocaleDateString()}</span>
            </div>
            <h3>{post.data.title}</h3>
            <p>{post.data.description}</p>
            <div class="read-more">Read More &rarr;</div>
          </a>
        ))
      )}
    </div>
  </main>
</Layout>

<style>
  .blog-list-container { max-width: 1200px; margin: 80px auto; padding: 0 20px; font-family: 'Inter', sans-serif; }
  .blog-hero { text-align: center; margin-bottom: 60px; }
  .blog-badge { background: #eff6ff; color: #2563eb; padding: 6px 14px; border-radius: 100px; font-size: 0.75rem; font-weight: 800; text-transform: uppercase; letter-spacing: 1px; }
  .blog-hero h1 { font-size: 3.5rem; font-weight: 900; color: #0f172a; margin: 20px 0 10px; letter-spacing: -2px; }
  .gradient-text { background: linear-gradient(135deg, #4f46e5 0%, #2563eb 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
  .blog-hero p { color: #64748b; font-size: 1.15rem; max-width: 600px; margin: 0 auto; }

  .blog-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(350px, 1fr)); gap: 30px; }
  .post-card { 
    background: #ffffff; 
    border: 1px solid #f1f5f9; 
    padding: 35px; 
    border-radius: 24px; 
    text-decoration: none; 
    display: flex; 
    flex-direction: column; 
    transition: all 0.3s ease;
    box-shadow: 0 4px 6px -1px rgba(0,0,0,0.02);
  }
  .post-card:hover { transform: translateY(-5px); border-color: #2563eb; box-shadow: 0 20px 25px -5px rgba(0,0,0,0.05); }

  .post-meta { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; font-size: 0.8rem; font-weight: 700; }
  .post-cat { color: #4f46e5; text-transform: uppercase; letter-spacing: 1px; }
  .post-date { color: #94a3b8; }

  .post-card h3 { font-size: 1.5rem; font-weight: 800; color: #0f172a; margin-bottom: 15px; line-height: 1.3; }
  .post-card p { color: #64748b; font-size: 1rem; line-height: 1.6; flex-grow: 1; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
  
  .read-more { margin-top: 25px; color: #2563eb; font-weight: 800; font-size: 0.9rem; transition: transform 0.2s; }
  .post-card:hover .read-more { transform: translateX(5px); }
  
  .no-posts { text-align: center; grid-column: 1/-1; padding: 60px; color: #94a3b8; font-size: 1.2rem; }

  @media (max-width: 768px) {
    .blog-hero h1 { font-size: 2.5rem; }
    .blog-grid { grid-template-columns: 1fr; }
  }
</style>