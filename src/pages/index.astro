---
import Layout from '../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';

// 1. ARAÇLAR LİSTESİ (Değişmedi)
const allTools = [
  { name: 'IP Address Lookup', cat: 'IP', href: '/tools/ip-lookup', desc: 'Find location, ASN, and ISP details for any IP.' },
  { name: 'IP WHOIS Lookup', cat: 'IP', href: '/tools/ip-whois', desc: 'Check domain registration and WHOIS records.' },
  { name: 'Port Scanner', cat: 'IP', href: '/tools/port-scanner', desc: 'Scan open ports to analyze server vulnerabilities.' },
  { name: 'Speed Test', cat: 'IP', href: '/tools/speed-test', desc: 'Test your network download and upload latency.' },
  { name: 'Security Auditor', cat: 'Security', href: '/tools/security-auditor', desc: 'Analyze public security postures and headers.' },
  { name: 'Password Strength', cat: 'Security', href: '/tools/password-strength', desc: 'Test password entropy and crack time locally.' },
  { name: 'Domain Trust', cat: 'Security', href: '/tools/domain-trust', desc: 'Check the reputation and blacklist status of a domain.' },
  { name: 'Compliance Auditor', cat: 'Security', href: '/tools/compliance-auditor', desc: 'Self-assess against ISO 27001 and GDPR.' },
  { name: 'SEO Analyzer', cat: 'SEO', href: '/tools/seo-analyzer', desc: 'Audit meta tags, structure, and on-page SEO.' },
  { name: 'Image Optimizer', cat: 'SEO', href: '/tools/image-optimizer', desc: 'Compress images in-browser without quality loss.' },
  { name: 'Speed Analyzer', cat: 'SEO', href: '/tools/speed-analyzer', desc: 'Test Core Web Vitals and page load performance.' },
  { name: 'Robots.txt Gen', cat: 'SEO', href: '/tools/robots-txt', desc: 'Generate a perfect robots.txt for search engines.' },
  { name: 'VPN Leak Test', cat: 'Privacy', href: '/tools/vpn-leak-test', desc: 'Check if your browser leaks your real IP via WebRTC.' },
  { name: 'Browser Fingerprint', cat: 'Privacy', href: '/tools/browser-fingerprint', desc: 'See what tracking data your browser reveals.' },
  { name: 'Proxy Check', cat: 'Privacy', href: '/tools/proxy-check', desc: 'Detect if an IP is a VPN, Proxy, or Tor node.' },
  { name: 'Hide My IP', cat: 'Privacy', href: '/tools/hide-ip', desc: 'Learn how to mask your digital footprint safely.' },
  { name: 'Web Scraper & Intel', cat: 'Data', href: '/tools/web-scraper', desc: 'Extract metadata and structured data from URLs.' },
  { name: 'Tech Stack Spy', cat: 'Data', href: '/tools/tech-stack-spy', desc: 'Identify frameworks and CMS powering a site.' },
  { name: 'Link Finder', cat: 'Data', href: '/tools/link-finder', desc: 'Extract all internal and external links from a page.' },
  { name: 'API Latency Tester', cat: 'Data', href: '/tools/api-latency', desc: 'Measure the response time of REST APIs.' }
];

// 2. OTOMATİK GERÇEK BLOG ÇEKME MANTIĞI (Garantili Versiyon)
const posts = await getCollection('blog');
const latestPosts = posts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<Layout title="Enterprise Security Suite">
  <main class="dash-container">
    <header class="dash-hero">
      <div class="dash-badge"><span class="live-dot"></span> Enterprise-Grade Infrastructure</div>
      <h1>Trusted Network <span class="gradient-text">Intelligence</span></h1>
      <p>The professional standard for IP analysis, security auditing, and SEO optimization. Fast, local, and incredibly precise.</p>
      <div class="dash-search-box">
        <input type="text" id="toolSearch" placeholder="Search 20+ professional tools (e.g., 'IP', 'Security')..." autocomplete="off" />
        <div class="search-kbd">âŒ˜ K</div>
      </div>
    </header>

    <div class="dash-filters">
      <button class="dash-chip active" data-filter="all">All Tools</button>
      <button class="dash-chip" data-filter="IP">IP Tools</button>
      <button class="dash-chip" data-filter="Security">Security</button>
      <button class="dash-chip" data-filter="SEO">SEO</button>
      <button class="dash-chip" data-filter="Privacy">Privacy</button>
      <button class="dash-chip" data-filter="Data">Data</button>
    </div>

    <section class="dash-grid" id="toolsGrid">
      {allTools.map(tool => (
        <a href={tool.href} class="dash-card" data-category={tool.cat} data-name={tool.name.toLowerCase()}>
          <div class="dash-card-header">
            <span class={`dash-cat-badge dash-cat-${tool.cat.toLowerCase()}`}>{tool.cat}</span>
            <span class="dash-arrow">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
            </span>
          </div>
          <h3>{tool.name}</h3>
          <p>{tool.desc}</p>
        </a>
      ))}
    </section>
  </main>

  <section class="integrated-blog-section">
    <div class="blog-container">
      <div class="blog-header">
        <h2>Expert <span class="gradient-text-alt">Insights & Guides</span></h2>
        <p>Master network security and SEO with our latest publications.</p>
      </div>

      <div class="blog-grid">
        {latestPosts.length === 0 ? (
          <p style="text-align:center; color:#64748b; grid-column: 1 / -1; padding: 40px 0;">No articles published yet.</p>
        ) : (
          latestPosts.map((post) => (
            <a href={`/blog/${post.id}`} class="blog-card">
              <div class="blog-meta">
                <span class="blog-cat">Intelligence</span>
                <span class="blog-time">{post.data.pubDate.toLocaleDateString()}</span>
              </div>
              <h3>{post.data.title}</h3>
              <div class="blog-read-more">Read Article &rarr;</div>
            </a>
          ))
        )}
      </div>

      <div class="blog-footer">
        <a href="/blog" class="view-all-btn">Go to Blog</a>
      </div>
    </div>
  </section>
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const searchInput = document.getElementById('toolSearch') as HTMLInputElement;
    const chips = document.querySelectorAll('.dash-chip');
    const cards = document.querySelectorAll('.dash-card');

    function filterTools() {
      const query = searchInput.value.toLowerCase();
      const activeFilter = document.querySelector('.dash-chip.active')?.getAttribute('data-filter');
      cards.forEach(card => {
        const name = card.getAttribute('data-name') || '';
        const category = card.getAttribute('data-category') || '';
        (card as HTMLElement).style.display = (name.includes(query) && (activeFilter === 'all' || category === activeFilter)) ? 'flex' : 'none';
      });
    }

    searchInput?.addEventListener('input', filterTools);
    chips.forEach(chip => {
      chip.addEventListener('click', () => {
        chips.forEach(c => c.classList.remove('active'));
        chip.classList.add('active');
        filterTools();
      });
    });
  });
</script>

<style>
  .dash-container { max-width: 1280px; margin: 0 auto; padding: 60px 20px 80px; font-family: 'Inter', sans-serif; position: relative; }
  .dash-hero { text-align: center; margin-bottom: 50px; }
  .dash-badge { display: inline-flex; align-items: center; gap: 8px; background: #fff; border: 1px solid #e5e7eb; color: #374151; padding: 6px 16px; border-radius: 30px; font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 25px; }
  .live-dot { width: 8px; height: 8px; background: #2563eb; border-radius: 50%; box-shadow: 0 0 8px #2563eb; animation: pulse 2s infinite; }
  @keyframes pulse { 0% { opacity: 1; } 50% { opacity: 0.5; } 100% { opacity: 1; } }
  .dash-hero h1 { font-size: 3.5rem; font-weight: 900; color: #111827; margin: 0 0 15px 0; letter-spacing: -1.5px; }
  .gradient-text { background: linear-gradient(135deg, #2563eb 0%, #1e40af 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
  .dash-hero p { font-size: 1.15rem; color: #6b7280; max-width: 650px; margin: 0 auto; line-height: 1.6; }
  .dash-search-box { max-width: 650px; margin: 40px auto 0; position: relative; }
  .dash-search-box input { width: 100%; padding: 22px 25px; border-radius: 16px; border: 1px solid #e2e8f0; font-size: 1.15rem; outline: none; transition: all 0.3s; box-shadow: 0 20px 25px -5px rgba(0,0,0,0.05); }
  .search-kbd { position: absolute; right: 20px; top: 50%; transform: translateY(-50%); background: #f3f4f6; color: #6b7280; font-size: 12px; font-weight: 700; padding: 6px 10px; border-radius: 6px; border: 1px solid #e5e7eb; pointer-events: none; }
  .dash-filters { display: flex; justify-content: center; flex-wrap: wrap; gap: 12px; margin-bottom: 50px; }
  .dash-chip { background: #fff; border: 1px solid #e5e7eb; padding: 10px 22px; border-radius: 30px; cursor: pointer; font-weight: 600; font-size: 14px; color: #4b5563; transition: all 0.2s; }
  .dash-chip.active { background: #111827; color: #fff; border-color: #111827; }
  .dash-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(290px, 1fr)); gap: 24px; }
  .dash-card { background: #fff; border: 1px solid #f1f5f9; padding: 30px; border-radius: 20px; text-decoration: none; display: flex; flex-direction: column; transition: all 0.3s; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.02); }
  .dash-card:hover { transform: translateY(-6px); border-color: #3b82f6; box-shadow: 0 20px 25px -5px rgba(0,0,0,0.05); }
  .dash-card-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
  .dash-cat-badge { font-size: 11px; font-weight: 800; text-transform: uppercase; padding: 5px 12px; border-radius: 8px; letter-spacing: 0.5px; }
  .dash-cat-ip { background: #eff6ff; color: #1d4ed8; }
  .dash-cat-security { background: #fef2f2; color: #b91c1c; }
  .dash-cat-seo { background: #fffbeb; color: #b45309; }
  .dash-cat-privacy { background: #f5f3ff; color: #6d28d9; }
  .dash-cat-data { background: #ecfdf5; color: #047857; }
  .dash-arrow { color: #d1d5db; transition: all 0.3s; width: 24px; height: 24px; border-radius: 50%; background: #f9fafb; display: flex; align-items: center; justify-content: center; }
  .dash-card:hover .dash-arrow { color: #fff; background: #2563eb; transform: translateX(3px); }
  .dash-card h3 { margin: 0 0 10px 0; font-size: 1.25rem; font-weight: 800; color: #111827; }
  .dash-card p { margin: 0; font-size: 0.95rem; color: #64748b; line-height: 1.6; }

  /* BLOG SECTION */
  .integrated-blog-section { background: #f8fafc; border-top: 1px solid #e2e8f0; padding: 80px 20px; }
  .blog-container { max-width: 1280px; margin: 0 auto; }
  .blog-header { text-align: center; margin-bottom: 50px; }
  .blog-header h2 { font-size: 2.5rem; font-weight: 900; color: #111827; }
  .gradient-text-alt { background: linear-gradient(135deg, #059669 0%, #2563eb 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
  .blog-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 30px; margin-bottom: 50px; }
  .blog-card { background: #ffffff; border: 1px solid #e2e8f0; padding: 35px 30px; border-radius: 20px; text-decoration: none; transition: all 0.3s; }
  .blog-card:hover { border-color: #3b82f6; transform: translateY(-5px); }
  .blog-meta { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; font-size: 13px; font-weight: 700; }
  .blog-cat { color: #059669; text-transform: uppercase; background: #ecfdf5; padding: 4px 10px; border-radius: 6px; }
  .blog-time { color: #94a3b8; }
  .blog-card h3 { color: #0f172a; font-size: 1.35rem; font-weight: 800; margin-bottom: 25px; line-height: 1.4; }
  .blog-read-more { color: #3b82f6; font-size: 14px; font-weight: 700; }
  .view-all-btn { display: inline-block; background: #fff; color: #111827; border: 1px solid #cbd5e1; padding: 14px 28px; border-radius: 30px; font-weight: 700; text-decoration: none; transition: 0.3s; }
  .view-all-btn:hover { background: #f8fafc; border-color: #94a3b8; transform: translateY(-2px); }
</style>