---
import Layout from '../../layouts/MainLayout.astro';
export const prerender = true;
---
<Layout title="ASN Explorer & Autonomous System Lookup | DataSecureTools">
  <div style="max-width: 1300px; margin: 40px auto; padding: 0 20px; font-family: 'Inter', sans-serif; color: #0f172a;">
    
    <div style="width: 100%; height: 90px; background: #f8fafc; border: 1px dashed #cbd5e1; border-radius: 12px; margin-bottom: 30px; display: flex; align-items: center; justify-content: center; color: #94a3b8; font-size: 0.8rem;">
      ADVERTISEMENT - GOOGLE ADSENSE
    </div>

    <div style="display: grid; grid-template-columns: 1fr 340px; gap: 40px;">
      <main>
        <div style="background: #ffffff; border-radius: 32px; padding: 50px; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.03); border: 1px solid #f1f5f9;">
          <header style="margin-bottom: 40px;">
            <span style="background: #fff7ed; color: #f97316; padding: 6px 14px; border-radius: 100px; font-size: 0.85rem; font-weight: 700;">BGP INTELLIGENCE</span>
            <h1 style="font-size: 2.8rem; font-weight: 900; margin-top: 15px; letter-spacing: -1px;">ASN Explorer</h1>
            <p style="color: #64748b; font-size: 1.2rem; margin-top: 10px;">Deep dive into Autonomous System records, IP prefixes, and routing infrastructure.</p>
          </header>

          <div style="background: #f8fafc; padding: 8px; border-radius: 20px; display: flex; border: 1px solid #e2e8f0;">
            <input type="text" id="target" placeholder="Enter ASN (e.g. AS15169 or 15169)" style="flex: 1; padding: 18px 25px; border: none; background: transparent; outline: none; font-size: 1.1rem;" />
            <button id="runBtn" style="background: #0f172a; color: white; padding: 0 35px; border-radius: 14px; border: none; font-weight: 700; cursor: pointer;">EXPLORE ASN</button>
          </div>

          <div id="results" style="display: none; margin-top: 50px; animation: slideUp 0.6s ease-out;">
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; margin-bottom: 40px;">
              <div style="background: #ffffff; padding: 25px; border-radius: 24px; border: 1px solid #f1f5f9; box-shadow: 0 4px 6px rgba(0,0,0,0.02);">
                <span style="font-size: 0.75rem; font-weight: 800; color: #94a3b8;">OWNER / ENTITY</span>
                <div id="v-owner" style="font-size: 1.2rem; font-weight: 800; color: #0f172a; margin-top: 8px;">-</div>
              </div>
              <div style="background: #ffffff; padding: 25px; border-radius: 24px; border: 1px solid #f1f5f9; box-shadow: 0 4px 6px rgba(0,0,0,0.02);">
                <span style="font-size: 0.75rem; font-weight: 800; color: #94a3b8;">DOMAIN</span>
                <div id="v-domain" style="font-size: 1.2rem; font-weight: 800; color: #f97316; margin-top: 8px;">-</div>
              </div>
              <div style="background: #ffffff; padding: 25px; border-radius: 24px; border: 1px solid #f1f5f9; box-shadow: 0 4px 6px rgba(0,0,0,0.02);">
                <span style="font-size: 0.75rem; font-weight: 800; color: #94a3b8;">REGISTRY</span>
                <div id="v-rir" style="font-size: 1.2rem; font-weight: 800; color: #10b981; margin-top: 8px;">-</div>
              </div>
            </div>

            <div style="background: #0f172a; border-radius: 24px; padding: 40px; border: 1px solid #334155;">
              <span style="color: #64748b; font-size: 0.75rem; font-weight: 800; text-transform: uppercase; display: block; margin-bottom: 20px;">BGP Routing Intelligence Report</span>
              <pre id="v-raw" style="font-family: 'Fira Code', monospace; color: #38bdf8; font-size: 0.9rem; margin: 0; line-height: 1.6; white-space: pre-wrap;"></pre>
            </div>
          </div>
        </div>

        <article style="margin-top: 60px; line-height: 1.8; color: #475569;">
          <h2 style="color: #0f172a; font-size: 1.8rem; font-weight: 800;">What is an ASN and Why Track Autonomous Systems?</h2>
          <p style="margin-top: 20px;">An <strong>Autonomous System Number (ASN)</strong> is a unique identifier for a collection of IP networks managed by a single entity, such as an ISP, a tech giant, or a university. Using our <strong>ASN Explorer</strong>, you can uncover the backbone of the internet, identifying who controls specific IP ranges and how traffic is routed globally.</p>
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 30px; margin-top: 30px;">
            <div>
              <h3 style="color: #0f172a; font-size: 1.2rem; font-weight: 700;">Infrastructure Mapping</h3>
              <p style="font-size: 0.9rem;">Map out the digital footprint of any organization to understand their hosting provider or internal network capacity.</p>
            </div>
            <div>
              <h3 style="color: #0f172a; font-size: 1.2rem; font-weight: 700;">BGP Security Audit</h3>
              <p style="font-size: 0.9rem;">Monitor for BGP hijacking or routing leaks by verifying the authorized ASN for your mission-critical IP prefixes.</p>
            </div>
          </div>
        </article>
      </main>

      <aside>
        <div style="width: 100%; height: 600px; background: #f8fafc; border: 1px dashed #cbd5e1; border-radius: 24px; margin-bottom: 40px; display: flex; align-items: center; justify-content: center; color: #94a3b8; text-align: center; padding: 20px;">
          ADSENSE SKYSCRAPER AD
        </div>

        <div style="background: #f1f5f9; padding: 30px; border-radius: 32px;">
          <h3 style="font-size: 1.1rem; font-weight: 900; color: #0f172a; margin-bottom: 25px;">Network Advice</h3>
          <div style="display: flex; flex-direction: column; gap: 20px;">
            <div style="background: white; padding: 20px; border-radius: 18px; box-shadow: 0 4px 6px rgba(0,0,0,0.02);">
              <strong style="color: #f97316; display: block; margin-bottom: 5px; font-size: 0.9rem;">Peering Strategy</strong>
              <p style="font-size: 0.8rem; color: #64748b;">Analyze upstream ASNs to identify potential peering partners for lower latency.</p>
            </div>
            <div style="background: white; padding: 20px; border-radius: 18px; box-shadow: 0 4px 6px rgba(0,0,0,0.02);">
              <strong style="color: #10b981; display: block; margin-bottom: 5px; font-size: 0.9rem;">IP Reputation</strong>
              <p style="font-size: 0.8rem; color: #64748b;">If an ASN has a high volume of spam, its entire IP range may be deprioritized by firewalls.</p>
            </div>
          </div>
        </div>
      </aside>
    </div>
  </div>
</Layout>

<style>
  @keyframes slideUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
</style>

<script>
  const btn = document.getElementById('runBtn');
  btn?.addEventListener('click', async () => {
    let target = (document.getElementById('target') as HTMLInputElement).value.trim().toUpperCase();
    if(!target) return;
    
    // Temizleme: AS15169 -> 15169
    const asnNum = target.replace('AS', '');
    
    btn.innerText = "QUERYING BGP DB...";
    btn.disabled = true;

    try {
      // Motor: PeeringDB or IP-API (ASN focus)
      const response = await fetch(`https://api.allorigins.win/get?url=${encodeURIComponent('https://rdap.db.ripe.net/autnum/' + asnNum)}`);
      const json = await response.json();
      const data = JSON.parse(json.contents);

      if (!data.name && !data.handle) throw new Error("ASN not found");

      document.getElementById('v-owner').innerText = data.name || data.handle || 'N/A';
      document.getElementById('v-domain').innerText = data.entities ? data.entities[0].handle : 'N/A';
      document.getElementById('v-rir').innerText = data.port43 || 'RIPE / GLOBAL';
      document.getElementById('v-raw').innerText = JSON.stringify(data, null, 4);
      
      document.getElementById('results').style.display = "block";
      
    } catch (e) {
      alert("Error: ASN not found in global registries. Ensure you use the correct format (e.g. 15169).");
    } finally {
      btn.innerText = "EXPLORE ASN";
      btn.disabled = false;
    }
  });
</script>