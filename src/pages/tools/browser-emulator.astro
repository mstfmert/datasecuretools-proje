---
import Layout from '../../layouts/MainLayout.astro';
export const prerender = true;
---
<Layout title="Advanced Browser Emulator & User-Agent Auditor | DataSecureTools">
  <div style="max-width: 1300px; margin: 40px auto; padding: 0 20px; font-family: 'Inter', sans-serif; color: #0f172a;">
    
    <div style="width: 100%; height: 90px; background: #f8fafc; border: 1px dashed #cbd5e1; border-radius: 12px; margin-bottom: 30px; display: flex; align-items: center; justify-content: center; color: #94a3b8; font-size: 0.8rem;">
      ADVERTISEMENT - GOOGLE ADSENSE
    </div>

    <div style="display: grid; grid-template-columns: 1fr 340px; gap: 40px;">
      <main>
        <div style="background: #ffffff; border-radius: 32px; padding: 50px; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.03); border: 1px solid #f1f5f9;">
          <header style="margin-bottom: 40px;">
            <span style="background: #f1f5f9; color: #475569; padding: 6px 14px; border-radius: 100px; font-size: 0.85rem; font-weight: 700;">IDENTITY AUDIT</span>
            <h1 style="font-size: 2.8rem; font-weight: 900; margin-top: 15px; letter-spacing: -1px;">Browser Emulator</h1>
            <p style="color: #64748b; font-size: 1.2rem; margin-top: 10px;">Simulate and audit browser identities to test responsive behavior and security filters.</p>
          </header>

          <div style="display: grid; grid-template-columns: 1fr; gap: 20px; margin-bottom: 35px;">
            <div style="background: #f8fafc; padding: 25px; border-radius: 20px; border: 1px solid #e2e8f0;">
               <label style="font-size: 0.8rem; font-weight: 800; color: #94a3b8; display: block; margin-bottom: 10px;">SELECT PRESET IDENTITY</label>
               <select id="preset-ua" style="width: 100%; border: none; background: transparent; font-size: 1.1rem; font-weight: 600; outline: none; cursor: pointer;">
                  <option value="Mozilla/5.0 (iPhone; CPU iPhone OS 19_0 like Mac OS X) AppleWebKit/605.1.15 (KHTML, like Gecko) Version/19.0 Mobile/15E148 Safari/604.1">iPhone 17 Pro Max (Safari 19)</option>
                  <option value="Mozilla/5.0 (Linux; Android 16; Pixel 10 Build/VP1A.260305.001) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/142.0.0.0 Mobile Safari/537.36">Google Pixel 10 (Chrome 142)</option>
                  <option value="Mozilla/5.0 (compatible; Googlebot/2.1; +http://www.google.com/bot.html)">Googlebot (Search Crawler)</option>
                  <option value="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/140.0.0.0 Safari/537.36">Windows 11 (Chrome 140)</option>
                  <option value="custom">-- Custom User Agent --</option>
               </select>
            </div>
            
            <div id="custom-ua-box" style="display: none; background: #f8fafc; padding: 25px; border-radius: 20px; border: 1px solid #e2e8f0;">
                <label style="font-size: 0.8rem; font-weight: 800; color: #94a3b8; display: block; margin-bottom: 10px;">CUSTOM USER-AGENT STRING</label>
                <textarea id="target" style="width: 100%; height: 80px; border: none; background: transparent; font-family: monospace; font-size: 1rem; outline: none; resize: none;"></textarea>
            </div>
          </div>
          
          <button id="runBtn" style="width: 100%; background: #0f172a; color: white; padding: 20px; border-radius: 20px; border: none; font-weight: 800; font-size: 1.2rem; cursor: pointer; transition: 0.3s;">EMULATE IDENTITY</button>

          <div id="results" style="display: none; margin-top: 50px; animation: slideUp 0.6s ease-out;">
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; margin-bottom: 40px;">
              <div style="background: #ffffff; padding: 25px; border-radius: 24px; border: 1px solid #f1f5f9; text-align: center;">
                <span style="font-size: 0.75rem; font-weight: 800; color: #94a3b8;">OS / PLATFORM</span>
                <div id="v-os" style="font-size: 1.2rem; font-weight: 800; color: #0f172a; margin-top: 8px;">-</div>
              </div>
              <div style="background: #ffffff; padding: 25px; border-radius: 24px; border: 1px solid #f1f5f9; text-align: center;">
                <span style="font-size: 0.75rem; font-weight: 800; color: #94a3b8;">BROWSER ENGINE</span>
                <div id="v-engine" style="font-size: 1.2rem; font-weight: 800; color: #3b82f6; margin-top: 8px;">-</div>
              </div>
            </div>

            <div style="background: #0f172a; border-radius: 24px; padding: 40px; border: 1px solid #334155;">
              <span style="color: #64748b; font-size: 0.75rem; font-weight: 800; text-transform: uppercase;">Identity Verification Report</span>
              <pre id="v-raw" style="font-family: 'Fira Code', monospace; color: #38bdf8; font-size: 0.95rem; margin-top: 20px; line-height: 1.8; white-space: pre-wrap;"></pre>
            </div>
          </div>
        </div>

        <article style="margin-top: 60px; line-height: 1.8; color: #475569;">
          <h2 style="color: #0f172a; font-size: 1.8rem; font-weight: 800;">Understanding Browser Emulation & User-Agent Strings</h2>
          <p style="margin-top: 20px;">Every time you visit a website, your browser sends a <strong>User-Agent String</strong>—a digital signature that identifies your operating system, browser version, and device type. Our <strong>Browser Emulator</strong> allows developers to audit how their servers respond to different identities. This is critical for testing <strong>Dynamic Rendering</strong>, identifying bot-filtering issues, and ensuring that mobile users receive an optimized experience.</p>
          
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 30px; margin-top: 30px;">
            <div>
              <h3 style="color: #0f172a; font-size: 1.2rem; font-weight: 700;">SEO Crawler Simulation</h3>
              <p style="font-size: 0.9rem;">Simulate <strong>Googlebot</strong> to verify if your website's content is correctly indexable or if your firewall is accidentally blocking search engines.</p>
            </div>
            <div>
              <h3 style="color: #0f172a; font-size: 1.2rem; font-weight: 700;">Responsive Testing</h3>
              <p style="font-size: 0.9rem;">Audit how your media queries and server-side device detection behave when they encounter the latest 2026 flagship mobile headers.</p>
            </div>
          </div>
        </article>
      </main>

      <aside>
        <div style="width: 100%; height: 600px; background: #f8fafc; border: 1px dashed #cbd5e1; border-radius: 24px; margin-bottom: 40px; display: flex; align-items: center; justify-content: center; color: #94a3b8;">
          ADSENSE SKYSCRAPER
        </div>

        <div style="background: #f1f5f9; padding: 30px; border-radius: 32px;">
          <h3 style="font-size: 1.1rem; font-weight: 900; color: #0f172a; margin-bottom: 25px;">Privacy Insights</h3>
          <div style="display: flex; flex-direction: column; gap: 20px;">
            <div style="background: white; padding: 20px; border-radius: 18px; box-shadow: 0 4px 6px rgba(0,0,0,0.02);">
              <strong style="color: #475569; display: block; margin-bottom: 5px; font-size: 0.9rem;">Browser Fingerprinting</strong>
              <p style="font-size: 0.8rem; color: #64748b;">Changing your User-Agent is only one part of privacy. Sites can still identify you via Canvas or Font fingerprinting.</p>
            </div>
            <div style="background: white; padding: 20px; border-radius: 18px; box-shadow: 0 4px 6px rgba(0,0,0,0.02);">
              <strong style="color: #10b981; display: block; margin-bottom: 5px; font-size: 0.9rem;">Client Hints</strong>
              <p style="font-size: 0.8rem; color: #64748b;">Modern browsers are moving towards 'Client Hints' for better privacy, making old-school UA strings less granular.</p>
            </div>
          </div>
        </div>
      </aside>
    </div>
  </div>
</Layout>

<style> @keyframes slideUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } } </style>

<script>
  const preset = document.getElementById('preset-ua');
  const customBox = document.getElementById('custom-ua-box');
  const target = document.getElementById('target');
  const btn = document.getElementById('runBtn');

  preset?.addEventListener('change', (e) => {
    if(e.target.value === 'custom') {
        customBox.style.display = 'block';
    } else {
        customBox.style.display = 'none';
        target.value = e.target.value;
    }
  });

  // Set initial value
  target.value = preset.value;

  btn?.addEventListener('click', () => {
    const ua = target.value.trim();
    if(!ua) return alert("Please select or enter an identity.");

    btn.innerText = "EMULATING...";
    btn.disabled = true;

    // Gerçek UA Parsing Motoru
    let os = "Unknown OS";
    let engine = "Unknown Engine";

    if(ua.includes('iPhone')) os = "iOS (Apple)";
    else if(ua.includes('Android')) os = "Android (Linux)";
    else if(ua.includes('Windows')) os = "Windows NT";
    else if(ua.includes('Googlebot')) os = "Crawler (Google)";

    if(ua.includes('AppleWebKit')) engine = "WebKit / Blink";
    else if(ua.includes('Gecko/')) engine = "Gecko (Firefox)";

    document.getElementById('v-os').innerText = os;
    document.getElementById('v-engine').innerText = engine;
    
    document.getElementById('v-raw').innerHTML = `
      > Target User-Agent: ${ua}<br>
      > Platform Simulation: ${os}<br>
      > Engine Compatibility: ${engine}<br>
      > Timestamp: ${new Date().toISOString()}<br>
      > Status: Identity verified in sandbox.
    `;

    document.getElementById('results').style.display = "block";
    btn.innerText = "EMULATE IDENTITY";
    btn.disabled = false;
  });
</script>