export const prerender = true;
---
// src/pages/tools/cidr-calculator.astro
import Layout from '../../layouts/MainLayout.astro';
---

<Layout title="CIDR Calculator - DataSecureTools">
  <main class="tool-container">
    <section class="hero-section">
      <h1>CIDR Calculator</h1>
      <p>Convert IP ranges into CIDR notation or explore subnet details easily.</p>
    </section>

    <div class="tool-card">
      <div class="input-row">
        <div class="input-group">
          <label>Start IP</label>
          <input type="text" id="startIp" placeholder="192.168.1.0" value="10.0.0.0" />
        </div>
        <div class="input-group">
          <label>End IP</label>
          <input type="text" id="endIp" placeholder="192.168.1.255" value="10.0.0.255" />
        </div>
      </div>

      <button id="cidrBtn" class="calc-button">Generate CIDR Block</button>

      <div id="resultArea" class="result-display hidden">
        <div class="cidr-result">
          <span class="label">Matching CIDR</span>
          <h2 id="resCidr">10.0.0.0/24</h2>
        </div>

        <div class="details-grid">
          <div class="detail-item">
            <span>Total IPs</span>
            <strong id="resTotal">256</strong>
          </div>
          <div class="detail-item">
            <span>Mask</span>
            <strong id="resMask">255.255.255.0</strong>
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>

<script>
  function ipToInt(ip: string) {
    return ip.split('.').reduce((res, octet) => (res << 8) + parseInt(octet, 10), 0) >>> 0;
  }

  function intToIp(int: number) {
    return [(int >>> 24) & 0xFF, (int >>> 16) & 0xFF, (int >>> 8) & 0xFF, int & 0xFF].join('.');
  }

  function calculateCidr() {
    const start = ipToInt((document.getElementById('startIp') as HTMLInputElement).value);
    const end = ipToInt((document.getElementById('endIp') as HTMLInputElement).value);
    
    if (start > end) {
      alert("Start IP must be less than End IP");
      return;
    }

    const diff = end - start + 1;
    const cidr = 32 - Math.floor(Math.log2(diff));
    const mask = (0xFFFFFFFF << (32 - cidr)) >>> 0;

    document.getElementById('resCidr')!.textContent = `${intToIp(start & mask)}/${cidr}`;
    document.getElementById('resTotal')!.textContent = diff.toLocaleString();
    document.getElementById('resMask')!.textContent = intToIp(mask);

    document.getElementById('resultArea')?.classList.remove('hidden');
  }

  document.getElementById('cidrBtn')?.addEventListener('click', calculateCidr);
</script>

<style>
  .tool-container { max-width: 800px; margin: 60px auto; padding: 0 20px; font-family: 'Inter', sans-serif; }
  .hero-section { text-align: center; margin-bottom: 40px; }
  .hero-section h1 { font-size: 2.5rem; font-weight: 800; letter-spacing: -1px; }
  
  .tool-card { background: #fff; border: 1px solid #f3f4f6; border-radius: 16px; padding: 40px; box-shadow: 0 10px 25px rgba(0,0,0,0.05); }

  .input-row { display: flex; gap: 20px; margin-bottom: 25px; }
  .input-group { flex: 1; display: flex; flex-direction: column; gap: 8px; }
  .input-group label { font-size: 0.8rem; font-weight: 700; color: #6b7280; text-transform: uppercase; }
  .input-group input { padding: 12px; border: 1px solid #e5e7eb; border-radius: 8px; font-size: 1rem; outline: none; }

  .calc-button { width: 100%; background: #111827; color: #fff; border: none; padding: 15px; border-radius: 10px; font-weight: 700; cursor: pointer; margin-bottom: 30px; }

  .cidr-result { background: #f0f9ff; padding: 25px; border-radius: 12px; text-align: center; border: 1px solid #bae6fd; margin-bottom: 20px; }
  .cidr-result .label { font-size: 0.7rem; font-weight: 800; color: #0369a1; text-transform: uppercase; margin-bottom: 5px; display: block; }
  .cidr-result h2 { font-size: 2rem; color: #0c4a6e; margin: 0; font-family: 'Monaco', monospace; }

  .details-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
  .detail-item { background: #f9fafb; padding: 15px; border-radius: 8px; border: 1px solid #f3f4f6; text-align: center; }
  .detail-item span { font-size: 0.7rem; color: #9ca3af; text-transform: uppercase; display: block; margin-bottom: 4px; }
  .detail-item strong { color: #374151; font-size: 1rem; }

  .hidden { display: none; }
</style>

