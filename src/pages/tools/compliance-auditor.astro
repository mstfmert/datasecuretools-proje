---
import Layout from '../../layouts/MainLayout.astro';
export const prerender = true;
---
<Layout title="Global Compliance Auditor | GDPR, HIPAA & PCI-DSS Scanner | DataSecureTools">
  <div style="max-width: 1300px; margin: 40px auto; padding: 0 20px; font-family: 'Inter', sans-serif; color: #0f172a;">
    
    <div style="width: 100%; height: 90px; background: #f8fafc; border: 1px dashed #cbd5e1; border-radius: 12px; margin-bottom: 30px; display: flex; align-items: center; justify-content: center; color: #94a3b8; font-size: 0.8rem;">
      ADVERTISEMENT - GOOGLE ADSENSE
    </div>

    <div style="display: grid; grid-template-columns: 1fr 340px; gap: 40px;">
      <main>
        <div style="background: #ffffff; border-radius: 32px; padding: 50px; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.03); border: 1px solid #f1f5f9;">
          <header style="margin-bottom: 40px;">
            <span style="background: #eff6ff; color: #1d4ed8; padding: 6px 14px; border-radius: 100px; font-size: 0.85rem; font-weight: 700;">REGULATORY TECH</span>
            <h1 style="font-size: 2.8rem; font-weight: 900; margin-top: 15px; letter-spacing: -1px;">Compliance Auditor</h1>
            <p style="color: #64748b; font-size: 1.2rem; margin-top: 10px;">Audit web infrastructure for global data protection and security standards.</p>
          </header>

          <div style="background: #f8fafc; padding: 8px; border-radius: 20px; display: flex; border: 1px solid #e2e8f0; margin-bottom: 35px;">
            <input type="text" id="target" placeholder="Enter Website URL (e.g. https://google.com)" style="flex: 1; padding: 18px 25px; border: none; background: transparent; outline: none; font-size: 1.1rem;" />
            <button id="runBtn" style="background: #0f172a; color: white; padding: 0 35px; border-radius: 14px; border: none; font-weight: 700; cursor: pointer; transition: 0.3s;">START AUDIT</button>
          </div>

          <div id="results" style="display: none; animation: slideUp 0.6s ease-out;">
            <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 40px; background: #f8fafc; padding: 30px; border-radius: 24px;">
                <div>
                    <div style="font-size: 0.8rem; font-weight: 800; color: #94a3b8; text-transform: uppercase;">Compliance Health Score</div>
                    <div id="v-score" style="font-size: 3.5rem; font-weight: 900; color: #1d4ed8;">0%</div>
                </div>
                <div id="v-badge" style="padding: 10px 20px; border-radius: 12px; font-weight: 800; font-size: 0.9rem;">-</div>
            </div>

            <div id="check-list" style="display: flex; flex-direction: column; gap: 15px; margin-bottom: 40px;">
                </div>

            <div style="background: #0f172a; border-radius: 24px; padding: 40px; border: 1px solid #334155;">
              <span style="color: #64748b; font-size: 0.75rem; font-weight: 800; text-transform: uppercase;">Technical Audit Logs</span>
              <pre id="v-raw" style="font-family: 'Fira Code', monospace; color: #38bdf8; font-size: 0.85rem; margin-top: 20px; line-height: 1.6; white-space: pre-wrap;"></pre>
            </div>
          </div>
        </div>

        <article style="margin-top: 60px; line-height: 1.8; color: #475569;">
          <h2 style="color: #0f172a; font-size: 1.8rem; font-weight: 800;">Digital Compliance in the Age of Privacy</h2>
          <p style="margin-top: 20px;">Meeting global regulations like <strong>GDPR (General Data Protection Regulation)</strong> and <strong>PCI-DSS</strong> is no longer optional. Our <strong>Compliance Auditor</strong> performs a non-intrusive scan of your public-facing infrastructure to ensure that data encryption and security headers are correctly implemented. This helps businesses mitigate legal risks and build trust with their users.</p>
          
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 30px; margin-top: 30px;">
            <div>
              <h3 style="color: #0f172a; font-size: 1.2rem; font-weight: 700;">Data Protection (GDPR)</h3>
              <p style="font-size: 0.9rem;">Verify if SSL certificates are valid and if security headers like HSTS are preventing man-in-the-middle attacks on user data.</p>
            </div>
            <div>
              <h3 style="color: #0f172a; font-size: 1.2rem; font-weight: 700;">Financial Security (PCI)</h3>
              <p style="font-size: 0.9rem;">Audit the server environment to ensure that payment-related data is handled over encrypted channels with secure configurations.</p>
            </div>
          </div>
        </article>
      </main>

      <aside>
        <div style="width: 100%; height: 600px; background: #f8fafc; border: 1px dashed #cbd5e1; border-radius: 24px; margin-bottom: 40px; display: flex; align-items: center; justify-content: center; color: #94a3b8;">
          ADSENSE SKYSCRAPER AD
        </div>

        <div style="background: #f1f5f9; padding: 30px; border-radius: 32px;">
          <h3 style="font-size: 1.1rem; font-weight: 900; color: #0f172a; margin-bottom: 25px;">Legal Strategy</h3>
          <div style="display: flex; flex-direction: column; gap: 20px;">
            <div style="background: white; padding: 20px; border-radius: 18px;">
              <strong style="color: #1d4ed8; display: block; margin-bottom: 5px; font-size: 0.9rem;">HSTS Preload</strong>
              <p style="font-size: 0.8rem; color: #64748b;">Submit your domain to the HSTS preload list to ensure browsers never connect via insecure HTTP.</p>
            </div>
            <div style="background: white; padding: 20px; border-radius: 18px;">
              <strong style="color: #10b981; display: block; margin-bottom: 5px; font-size: 0.9rem;">Cookie Attributes</strong>
              <p style="font-size: 0.8rem; color: #64748b;">Ensure all cookies use the 'Secure' and 'HttpOnly' flags to comply with HIPAA and GDPR standards.</p>
            </div>
          </div>
        </div>
      </aside>
    </div>
  </div>
</Layout>

<style> @keyframes slideUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } } </style>

<script>
  const btn = document.getElementById('runBtn');
  btn?.addEventListener('click', async () => {
    let url = (document.getElementById('target') as HTMLInputElement).value.trim();
    if(!url) return alert("Please enter a URL.");
    if(!url.startsWith('http')) url = 'https://' + url;

    btn.innerText = "AUDITING COMPLIANCE...";
    btn.disabled = true;

    try {
      // Motor: Proxy üzerinden Header ve SSL denetimi
      const proxyUrl = `https://api.allorigins.win/get?url=${encodeURIComponent(url)}`;
      const response = await fetch(proxyUrl);
      const json = await response.json();
      const headers = json.status.headers || {};
      
      const checks = [
        { n: 'HTTPS Encryption', v: url.startsWith('https'), d: 'Mandatory for GDPR & HIPAA' },
        { n: 'HSTS Header', v: !!headers['strict-transport-security'], d: 'Strict Transport Security enforcement' },
        { n: 'X-Frame-Options', v: !!headers['x-frame-options'], d: 'Prevents Clickjacking attacks' },
        { n: 'CSP Policy', v: !!headers['content-security-policy'], d: 'Mitigates XSS vulnerabilities' },
        { n: 'X-Content-Type', v: !!headers['x-content-type-options'], d: 'Prevents MIME type sniffing' }
      ];

      const passCount = checks.filter(c => c.v).length;
      const score = Math.round((passCount / checks.length) * 100);

      document.getElementById('v-score').innerText = score + "%";
      const badge = document.getElementById('v-badge');
      badge.innerText = score > 70 ? 'COMPLIANT' : 'NON-COMPLIANT';
      badge.style.background = score > 70 ? '#ecfdf5' : '#fff1f2';
      badge.style.color = score > 70 ? '#10b981' : '#e11d48';

      const listDiv = document.getElementById('check-list');
      listDiv.innerHTML = checks.map(c => `
        <div style="background:white; padding:15px 25px; border-radius:18px; border:1px solid #f1f5f9; display:flex; justify-content:space-between; align-items:center;">
            <div>
                <strong style="color:#0f172a; font-size:0.95rem;">${c.n}</strong>
                <div style="font-size:0.75rem; color:#94a3b8;">${c.d}</div>
            </div>
            <div style="font-size:1.2rem;">${c.v ? '✅' : '❌'}</div>
        </div>
      `).join('');

      document.getElementById('v-raw').innerText = `[AUDIT]: ${url}\n[SCORE]: ${score}/100\n[REASONING]: ${passCount} of ${checks.length} critical privacy headers found.\n[TIMESTAMP]: ${new Date().toISOString()}\n--------------------------------\n` + JSON.stringify(headers, null, 4);
      document.getElementById('results').style.display = "block";

    } catch (e) {
      alert("Audit Failed: The target server is blocking our crawler. Check URL format.");
    } finally {
      btn.innerText = "START AUDIT";
      btn.disabled = false;
    }
  });
</script>