---
import Layout from '../../layouts/MainLayout.astro';
export const prerender = true;
---
<Layout title="DNS Lookup & Records Analyzer | Professional Network Audit | DataSecureTools">
  <div style="max-width: 1300px; margin: 40px auto; padding: 0 20px; font-family: 'Inter', sans-serif; color: #0f172a;">
    
    <div style="width: 100%; height: 90px; background: #f8fafc; border: 1px dashed #cbd5e1; border-radius: 12px; margin-bottom: 30px; display: flex; align-items: center; justify-content: center; color: #94a3b8; font-size: 0.8rem;">
      ADVERTISEMENT - GOOGLE ADSENSE
    </div>

    <div style="display: grid; grid-template-columns: 1fr 340px; gap: 40px;">
      <main>
        <div style="background: #ffffff; border-radius: 32px; padding: 50px; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.03); border: 1px solid #f1f5f9;">
          <header style="margin-bottom: 40px;">
            <span style="background: #e0f2fe; color: #0369a1; padding: 6px 14px; border-radius: 100px; font-size: 0.85rem; font-weight: 700;">DNS INTELLIGENCE</span>
            <h1 style="font-size: 2.8rem; font-weight: 900; margin-top: 15px; letter-spacing: -1px;">DNS Records Lookup</h1>
            <p style="color: #64748b; font-size: 1.2rem; margin-top: 10px;">Audit global DNS propagation and resolve multiple record types instantly.</p>
          </header>

          <div style="background: #f8fafc; padding: 8px; border-radius: 20px; display: flex; border: 1px solid #e2e8f0; margin-bottom: 30px;">
            <input type="text" id="target" placeholder="Enter Domain (e.g. google.com)" style="flex: 1; padding: 18px 25px; border: none; background: transparent; outline: none; font-size: 1.1rem;" />
            <button id="runBtn" style="background: #0f172a; color: white; padding: 0 35px; border-radius: 14px; border: none; font-weight: 700; cursor: pointer;">RESOLVE DNS</button>
          </div>

          <div id="results" style="display: none; animation: slideUp 0.6s ease-out;">
            <div id="record-container" style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 40px;">
                </div>

            <div style="background: #0f172a; border-radius: 24px; padding: 40px;">
              <span style="color: #64748b; font-size: 0.75rem; font-weight: 800; text-transform: uppercase;">Full DNS Authority Log</span>
              <pre id="v-raw" style="font-family: 'Fira Code', monospace; color: #38bdf8; font-size: 0.9rem; margin-top: 20px; line-height: 1.6; white-space: pre-wrap;"></pre>
            </div>
          </div>
        </div>

        <article style="margin-top: 60px; line-height: 1.8; color: #475569;">
          <h2 style="color: #0f172a; font-size: 1.8rem; font-weight: 800;">The Importance of DNS Auditing for Modern Infrastructure</h2>
          <p style="margin-top: 20px;">A <strong>DNS Lookup</strong> is the primary step in diagnosing website accessibility and security. By analyzing <strong>A Records</strong>, <strong>MX Records</strong>, and <strong>TXT Records</strong> (like SPF and DKIM), network administrators can ensure proper mail delivery and domain verification. Our <strong>DNS Records Analyzer</strong> uses encrypted protocols to fetch real-time data directly from root nameservers.</p>
          
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 30px; margin-top: 30px;">
            <div>
              <h3 style="color: #0f172a; font-size: 1.2rem; font-weight: 700;">Propagation Checking</h3>
              <p style="font-size: 0.9rem;">Verify if your new DNS settings have correctly propagated across global nameservers like Google, Cloudflare, and OpenDNS.</p>
            </div>
            <div>
              <h3 style="color: #0f172a; font-size: 1.2rem; font-weight: 700;">Security Hardening</h3>
              <p style="font-size: 0.9rem;">Audit your TXT records to prevent email spoofing and ensure that your DMARC policies are correctly implemented.</p>
            </div>
          </div>
        </article>
      </main>

      <aside>
        <div style="width: 100%; height: 600px; background: #f8fafc; border: 1px dashed #cbd5e1; border-radius: 24px; margin-bottom: 40px; display: flex; align-items: center; justify-content: center; color: #94a3b8; text-align: center; padding: 20px;">
          ADSENSE SKYSCRAPER AD
        </div>

        <div style="background: #f0f9ff; padding: 30px; border-radius: 32px;">
          <h3 style="font-size: 1.1rem; font-weight: 900; color: #0f172a; margin-bottom: 25px;">DNS Growth Insights</h3>
          <div style="display: flex; flex-direction: column; gap: 20px;">
            <div style="background: white; padding: 20px; border-radius: 18px;">
              <strong style="color: #0369a1; display: block; margin-bottom: 5px; font-size: 0.9rem;">CNAME Optimization</strong>
              <p style="font-size: 0.8rem; color: #64748b;">Using CNAME Flattening can slightly reduce lookup times and improve SEO performance.</p>
            </div>
            <div style="background: white; padding: 20px; border-radius: 18px;">
              <strong style="color: #10b981; display: block; margin-bottom: 5px; font-size: 0.9rem;">TTL Efficiency</strong>
              <p style="font-size: 0.8rem; color: #64748b;">Lower your TTL values before a migration to ensure fast propagation and zero downtime.</p>
            </div>
          </div>
        </div>
      </aside>
    </div>
  </div>
</Layout>

<style>
  @keyframes slideUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
</style>

<script>
  const btn = document.getElementById('runBtn');
  const types = ['A', 'MX', 'NS', 'TXT', 'CNAME', 'AAAA'];

  btn?.addEventListener('click', async () => {
    let target = (document.getElementById('target') as HTMLInputElement).value.trim();
    if(!target) return;
    target = target.replace(/^(https?:\/\/)?(www\.)?/, '').split('/')[0];

    btn.innerText = "QUERYING CLUSTER...";
    btn.disabled = true;

    try {
      const container = document.getElementById('record-container');
      const rawPre = document.getElementById('v-raw');
      container.innerHTML = '';
      let rawOutput = "";

      // Multi-Type Parallel Query
      const results = await Promise.all(types.map(async (type) => {
        const resp = await fetch(`https://dns.google/resolve?name=${target}&type=${type}`);
        const data = await resp.json();
        return { type, data: data.Answer || [] };
      }));

      results.forEach(res => {
        rawOutput += `[${res.type} Records]\n` + JSON.stringify(res.data, null, 2) + "\n\n";
        
        const card = document.createElement('div');
        card.style.cssText = "background:white; padding:25px; border-radius:24px; border:1px solid #f1f5f9; box-shadow:0 10px 15px -3px rgba(0,0,0,0.02);";
        
        const values = res.data.map(d => `<div style="font-size:0.9rem; color:#0f172a; margin-top:5px; word-break:break-all;">${d.data}</div>`).join('') || '<div style="color:#94a3b8; font-size:0.8rem;">No records found</div>';
        
        card.innerHTML = `
          <span style="font-size:0.75rem; font-weight:800; color:#0369a1; text-transform:uppercase;">${res.type} RECORD</span>
          <div style="margin-top:10px;">${values}</div>
        `;
        container.appendChild(card);
      });

      rawPre.innerText = rawOutput;
      document.getElementById('results').style.display = "block";
      
    } catch (e) {
      alert("Resolution Error: Check your domain format or connection.");
    } finally {
      btn.innerText = "RESOLVE DNS";
      btn.disabled = false;
    }
  });
</script>