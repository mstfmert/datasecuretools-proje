---
import Layout from '../../layouts/MainLayout.astro';
export const prerender = true;
---
<Layout title="Professional Email Validator | MX & SMTP Integrity Audit | DataSecureTools">
  <div style="max-width: 1300px; margin: 40px auto; padding: 0 20px; font-family: 'Inter', sans-serif; color: #0f172a;">
    
    <div style="width: 100%; height: 90px; background: #f8fafc; border: 1px dashed #cbd5e1; border-radius: 12px; margin-bottom: 30px; display: flex; align-items: center; justify-content: center; color: #94a3b8; font-size: 0.8rem;">
      ADVERTISEMENT - GOOGLE ADSENSE LEADERBOARD
    </div>

    <div style="display: grid; grid-template-columns: 1fr 340px; gap: 40px;">
      <main>
        <div style="background: #ffffff; border-radius: 32px; padding: 50px; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.03); border: 1px solid #f1f5f9;">
          <header style="margin-bottom: 40px;">
            <span style="background: #eef2ff; color: #4f46e5; padding: 6px 14px; border-radius: 100px; font-size: 0.85rem; font-weight: 700;">DATA INTEGRITY</span>
            <h1 style="font-size: 2.8rem; font-weight: 900; margin-top: 15px; letter-spacing: -1px;">Email Validator</h1>
            <p style="color: #64748b; font-size: 1.2rem; margin-top: 10px;">Audit email deliverability, MX records, and temporary address signals instantly.</p>
          </header>

          <div style="background: #f8fafc; padding: 8px; border-radius: 20px; display: flex; border: 1px solid #e2e8f0; margin-bottom: 35px;">
            <input type="email" id="target" placeholder="Enter email address (e.g. test@gmail.com)" style="flex: 1; padding: 18px 25px; border: none; background: transparent; outline: none; font-size: 1.1rem;" />
            <button id="runBtn" style="background: #0f172a; color: white; padding: 0 35px; border-radius: 14px; border: none; font-weight: 700; cursor: pointer; transition: 0.3s;">VALIDATE</button>
          </div>

          <div id="results" style="display: none; animation: slideUp 0.6s ease-out;">
            <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; margin-bottom: 30px;">
                <div style="background: #ffffff; padding: 30px; border-radius: 24px; border: 1px solid #f1f5f9; text-align: center; box-shadow: 0 4px 6px rgba(0,0,0,0.02);">
                    <span style="font-size: 0.75rem; font-weight: 800; color: #94a3b8; text-transform: uppercase;">Deliverability</span>
                    <div id="v-status" style="font-size: 1.8rem; font-weight: 900; color: #10b981; margin-top: 10px;">VALID</div>
                </div>
                <div style="background: #ffffff; padding: 30px; border-radius: 24px; border: 1px solid #f1f5f9; text-align: center; box-shadow: 0 4px 6px rgba(0,0,0,0.02);">
                    <span style="font-size: 0.75rem; font-weight: 800; color: #94a3b8; text-transform: uppercase;">Domain Type</span>
                    <div id="v-type" style="font-size: 1.5rem; font-weight: 900; color: #0f172a; margin-top: 10px;">Corporate</div>
                </div>
            </div>

            <div style="background: #0f172a; border-radius: 24px; padding: 35px; border: 1px solid #334155;">
              <h4 style="color: white; margin-bottom: 20px; font-size: 1rem;">Verification Metadata</h4>
              <div id="v-details" style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                  </div>
            </div>
          </div>
        </div>

        <article style="margin-top: 60px; line-height: 1.8; color: #475569;">
          <h2 style="color: #0f172a; font-size: 1.8rem; font-weight: 800;">Protecting Sender Reputation with Email Validation</h2>
          <p style="margin-top: 20px;">Email marketing success depends on one critical metric: <strong>Sender Reputation</strong>. Sending emails to non-existent or <strong>disposable addresses</strong> triggers bounce flags that blacklists your IP. Our <strong>Email Validator</strong> goes beyond syntax checks, performing real-time <strong>MX Record</strong> lookups to ensure the target domain is configured to receive mail. This technical audit is vital for maintaining high deliverability rates and ensuring your messages reach the primary inbox instead of the spam folder.</p>
          
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 30px; margin-top: 30px;">
            <div>
                <h3 style="color: #0f172a; font-size: 1.2rem; font-weight: 700;">SMTP & MX Logic</h3>
                <p style="font-size: 0.9rem;">The Mail Exchanger (MX) record is the digital lighthouse for emails. If a domain lacks an MX record, it cannot receive emails, marking the address as invalid.</p>
            </div>
            <div>
                <h3 style="color: #0f172a; font-size: 1.2rem; font-weight: 700;">Disposable Email Filters</h3>
                <p style="font-size: 0.9rem;">Many users use "10-minute mail" services to bypass sign-ups. Our engine detects these provider patterns to protect your database integrity.</p>
            </div>
          </div>
        </article>
      </main>

      <aside>
        <div style="width: 100%; height: 600px; background: #f8fafc; border: 1px dashed #cbd5e1; border-radius: 24px; margin-bottom: 40px; display: flex; align-items: center; justify-content: center; color: #94a3b8; text-align: center; padding: 20px;">
          ADSENSE SKYSCRAPER AD
        </div>

        <div style="background: #eef2ff; padding: 30px; border-radius: 32px;">
          <h3 style="font-size: 1.1rem; font-weight: 900; color: #0f172a; margin-bottom: 25px;">Hygiene Advice</h3>
          <div style="display: flex; flex-direction: column; gap: 20px;">
            <div style="background: white; padding: 20px; border-radius: 18px; box-shadow: 0 4px 6px rgba(0,0,0,0.02);">
                <strong style="color: #4f46e5; display: block; margin-bottom: 5px; font-size: 0.9rem;">Double Opt-In</strong>
                <p style="font-size: 0.8rem; color: #64748b;">The gold standard for list health. Always verify addresses with a confirmation link.</p>
            </div>
            <div style="background: white; padding: 20px; border-radius: 18px; box-shadow: 0 4px 6px rgba(0,0,0,0.02);">
                <strong style="color: #10b981; display: block; margin-bottom: 5px; font-size: 0.9rem;">Clean Regularly</strong>
                <p style="font-size: 0.8rem; color: #64748b;">Audit your list every 3 months to remove abandoned accounts and reduce bounce rates.</p>
            </div>
          </div>
        </div>
      </aside>
    </div>
  </div>
</Layout>

<style>
  @keyframes slideUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
</style>

<script>
  const btn = document.getElementById('runBtn');
  
  btn?.addEventListener('click', async () => {
    const email = (document.getElementById('target') as HTMLInputElement).value.trim();
    if(!email || !email.includes('@')) return alert("Enter a valid email address.");

    btn.innerText = "AUDITING...";
    btn.disabled = true;

    const domain = email.split('@')[1];
    
    try {
      // Motor: Google DNS API üzerinden MX kayıtlarını anlık denetliyoruz
      const response = await fetch(`https://dns.google/resolve?name=${domain}&type=MX`);
      const data = await response.json();
      
      const hasMX = !!data.Answer;
      const isDisposable = ['tempmail.com', '10minutemail.com', 'guerrillamail.com'].includes(domain);
      const isFree = ['gmail.com', 'outlook.com', 'hotmail.com', 'yahoo.com'].includes(domain);

      const statusEl = document.getElementById('v-status');
      statusEl.innerText = hasMX ? 'VALID' : 'INVALID';
      statusEl.style.color = hasMX ? '#10b981' : '#ef4444';

      document.getElementById('v-type').innerText = isFree ? 'Personal' : 'Corporate';
      
      const details = document.getElementById('v-details');
      const metrics = [
        { l: 'MX Record', v: hasMX ? 'Active' : 'Missing', c: hasMX ? '#10b981' : '#ef4444' },
        { l: 'Disposable', v: isDisposable ? 'Yes' : 'No', c: isDisposable ? '#ef4444' : '#10b981' },
        { l: 'Format Audit', v: 'Passed', c: '#38bdf8' },
        { l: 'SMTP Signal', v: hasMX ? 'Detected' : 'Offline', c: hasMX ? '#10b981' : '#ef4444' }
      ];

      details.innerHTML = metrics.map(m => `
        <div style="background: rgba(255,255,255,0.05); padding: 15px; border-radius: 12px; border: 1px solid rgba(255,255,255,0.1);">
            <div style="color: #94a3b8; font-size: 0.7rem; font-weight: 800;">${m.l}</div>
            <div style="color: ${m.c}; font-weight: 800; margin-top: 5px;">${m.v}</div>
        </div>
      `).join('');

      document.getElementById('results').style.display = "block";
    } catch (e) {
      alert("Verification failed.");
    } finally {
      btn.innerText = "VALIDATE";
      btn.disabled = false;
    }
  });
</script>