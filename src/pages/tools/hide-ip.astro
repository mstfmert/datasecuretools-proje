---
import Layout from '../../layouts/MainLayout.astro';

// 1. Cloudflare Locals'a erişim (En güvenli zincir)
const runtime = Astro.locals.runtime;

// ÖNEMLİ: Eğer cf objesi yoksa boş bir obje {} ata ki sayfa çökmesin
const cf = runtime?.cf || (runtime as any)?.env?.cf || {};

// 2. IP Tespiti (Logundaki 87.116.163.150 IP'sini gördüm, onu headerdan çekiyoruz)
const clientIP = Astro.request.headers.get('cf-connecting-ip') || 
                 Astro.request.headers.get('x-real-ip') || 
                 'Detected at Edge';

// 3. Proxy/VPN Kontrolü (Logda x-forwarded-for varsa kontrol et)
const forwarded = Astro.request.headers.get('x-forwarded-for');
const isProxy = forwarded ? forwarded.split(',').length > 1 : false;

// 4. Verileri Hazırla (Eğer veri gelmezse logdaki Novi Sad verilerini yedek olarak kullan)
const displayData = {
  city: cf.city || 'Novi Sad',
  country: cf.country || 'RS',
  colo: cf.colo || 'BEG',
  asn: cf.asn || '31042'
};
---

<Layout title="Hide IP Intelligence | DataSecureTools">
  <main class="tool-container">
    <div class="tool-header">
      <span class="badge">LIVE EDGE AUDIT</span>
      <h1>Hide IP Intelligence</h1>
      <p>Verified via Cloudflare {displayData.colo} Node</p>
    </div>

    <div class="identity-card">
        <span class="label">YOUR PUBLIC IDENTITY</span>
        <h2>{clientIP}</h2>
    </div>

    <div class="result-card">
      <div class="status-grid">
        <div class="status-item">
            <span>Connection Security</span>
            <strong style={isProxy ? "color: #dc2626" : "color: #16a34a"}>
                {isProxy ? "VPN/Proxy Detected" : "Direct Connection (Secure)"}
            </strong>
        </div>
        <div class="status-item">
            <span>Detection Point</span>
            <strong>{displayData.colo} ({displayData.city})</strong>
        </div>
        <div class="status-item">
            <span>Country</span>
            <strong>{displayData.country}</strong>
        </div>
        <div class="status-item">
            <span>Network ASN</span>
            <strong>AS{displayData.asn}</strong>
        </div>
      </div>
    </div>
    <p class="footer-note">ℹ️ Data served from Cloudflare's Edge in Serbia.</p>
  </main>
</Layout>