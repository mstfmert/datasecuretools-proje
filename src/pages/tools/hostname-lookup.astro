---
import Layout from '../../layouts/MainLayout.astro';
export const prerender = true;
---
<Layout title="Hostname Lookup & Reverse DNS (PTR) Tool | DataSecureTools">
  <div style="max-width: 1300px; margin: 40px auto; padding: 0 20px; font-family: 'Inter', sans-serif; color: #0f172a;">
    
    <div style="width: 100%; height: 90px; background: #f8fafc; border: 1px dashed #cbd5e1; border-radius: 12px; margin-bottom: 30px; display: flex; align-items: center; justify-content: center; color: #94a3b8; font-size: 0.8rem;">
      ADVERTISEMENT - GOOGLE ADSENSE
    </div>

    <div style="display: grid; grid-template-columns: 1fr 340px; gap: 40px;">
      <main>
        <div style="background: #ffffff; border-radius: 32px; padding: 50px; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.03); border: 1px solid #f1f5f9;">
          <header style="margin-bottom: 40px;">
            <span style="background: #eef2ff; color: #6366f1; padding: 6px 14px; border-radius: 100px; font-size: 0.85rem; font-weight: 700;">REVERSE DNS</span>
            <h1 style="font-size: 2.8rem; font-weight: 900; margin-top: 15px; letter-spacing: -1px;">Hostname Lookup</h1>
            <p style="color: #64748b; font-size: 1.2rem; margin-top: 10px;">Identify hostnames and PTR records associated with any IP address or domain.</p>
          </header>

          <div style="background: #f8fafc; padding: 8px; border-radius: 20px; display: flex; border: 1px solid #e2e8f0;">
            <input type="text" id="target" placeholder="Enter IP or Hostname (e.g. 8.8.8.8 or dns.google)" style="flex: 1; padding: 18px 25px; border: none; background: transparent; outline: none; font-size: 1.1rem;" />
            <button id="runBtn" style="background: #0f172a; color: white; padding: 0 35px; border-radius: 14px; border: none; font-weight: 700; cursor: pointer;">RESOLVE HOST</button>
          </div>

          <div id="results" style="display: none; margin-top: 50px; animation: slideUp 0.6s ease-out;">
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; margin-bottom: 40px;">
              <div style="background: #ffffff; padding: 25px; border-radius: 24px; border: 1px solid #f1f5f9; box-shadow: 0 4px 6px rgba(0,0,0,0.02);">
                <span style="font-size: 0.75rem; font-weight: 800; color: #94a3b8;">PRIMARY HOST</span>
                <div id="v-host" style="font-size: 1.2rem; font-weight: 800; color: #0f172a; margin-top: 8px; word-break: break-all;">-</div>
              </div>
              <div style="background: #ffffff; padding: 25px; border-radius: 24px; border: 1px solid #f1f5f9; box-shadow: 0 4px 6px rgba(0,0,0,0.02);">
                <span style="font-size: 0.75rem; font-weight: 800; color: #94a3b8;">RESOLVED IP</span>
                <div id="v-ip" style="font-size: 1.2rem; font-weight: 800; color: #6366f1; margin-top: 8px;">-</div>
              </div>
            </div>

            <div style="background: #0f172a; border-radius: 24px; padding: 40px;">
              <span style="color: #64748b; font-size: 0.75rem; font-weight: 800; text-transform: uppercase;">Technical Resolution Log</span>
              <pre id="v-raw" style="font-family: 'Fira Code', monospace; color: #38bdf8; font-size: 0.9rem; margin-top: 20px; line-height: 1.6; white-space: pre-wrap;"></pre>
            </div>
          </div>
        </div>

        <article style="margin-top: 60px; line-height: 1.8; color: #475569;">
          <h2 style="color: #0f172a; font-size: 1.8rem; font-weight: 800;">What is Hostname Lookup and Why is it Important?</h2>
          <p style="margin-top: 20px;">A <strong>Hostname Lookup</strong> (often involving Reverse DNS) is the process of resolving an IP address back to its human-readable domain name. This is crucial for verifying server identities, auditing mail server security (via PTR records), and identifying the origin of network traffic. Our tool provides a seamless <strong>Reverse DNS (rDNS) audit</strong> for professional network diagnostics.</p>
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 30px; margin-top: 30px;">
            <div>
              <h3 style="color: #0f172a; font-size: 1.2rem; font-weight: 700;">Mail Server Reputation</h3>
              <p style="font-size: 0.9rem;">Properly configured PTR records are a major signal for anti-spam filters. Verify your server's hostname to ensure email deliverability.</p>
            </div>
            <div>
              <h3 style="color: #0f172a; font-size: 1.2rem; font-weight: 700;">Infrastructure Visibility</h3>
              <p style="font-size: 0.9rem;">Convert obscure IP logs into recognizable hostnames to better understand your web traffic and API consumers.</p>
            </div>
          </div>
        </article>
      </main>

      <aside>
        <div style="width: 100%; height: 600px; background: #f8fafc; border: 1px dashed #cbd5e1; border-radius: 24px; margin-bottom: 40px; display: flex; align-items: center; justify-content: center; color: #94a3b8; text-align: center; padding: 20px;">
          ADSENSE SKYSCRAPER AD
        </div>

        <div style="background: #f1f5f9; padding: 30px; border-radius: 32px;">
          <h3 style="font-size: 1.1rem; font-weight: 900; color: #0f172a; margin-bottom: 25px;">Network Advice</h3>
          <div style="display: flex; flex-direction: column; gap: 20px;">
            <div style="background: white; padding: 20px; border-radius: 18px;">
              <strong style="color: #6366f1; display: block; margin-bottom: 5px; font-size: 0.9rem;">PTR Alignment</strong>
              <p style="font-size: 0.8rem; color: #64748b;">Ensure your Reverse DNS matches your A record. Misalignment can trigger security warnings in enterprise firewalls.</p>
            </div>
            <div style="background: white; padding: 20px; border-radius: 18px;">
              <strong style="color: #10b981; display: block; margin-bottom: 5px; font-size: 0.9rem;">Identity Audit</strong>
              <p style="font-size: 0.8rem; color: #64748b;">Use Hostname Lookup to verify if a CDN IP belongs to a trusted provider like Cloudflare or Akamai.</p>
            </div>
          </div>
        </div>
      </aside>
    </div>
  </div>
</Layout>

<style>
  @keyframes slideUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
</style>

<script>
  const btn = document.getElementById('runBtn');
  btn?.addEventListener('click', async () => {
    let target = (document.getElementById('target') as HTMLInputElement).value.trim();
    if(!target) return;

    btn.innerText = "RESOLVING...";
    btn.disabled = true;

    try {
      // Step 1: DNS Resolve via Google HTTPS DNS
      const isIp = /^[0-9.]+$/.test(target);
      const queryType = isIp ? 'PTR' : 'A';
      // Reverse IP for PTR query if it's an IP
      const queryName = isIp ? target.split('.').reverse().join('.') + '.in-addr.arpa' : target;

      const resp = await fetch(`https://dns.google/resolve?name=${queryName}&type=${queryType}`);
      const data = await resp.json();

      if (!data.Answer) throw new Error("No resolution records found.");

      const resultHost = isIp ? data.Answer[0].data : target;
      const resultIp = isIp ? target : data.Answer[0].data;

      document.getElementById('v-host').innerText = resultHost;
      document.getElementById('v-ip').innerText = resultIp;
      document.getElementById('v-raw').innerText = JSON.stringify(data, null, 4);
      
      document.getElementById('results').style.display = "block";
      
    } catch (e) {
      alert("Error: Resolution failed. The target may not have a valid PTR or A record.");
    } finally {
      btn.innerText = "RESOLVE HOST";
      btn.disabled = false;
    }
  });
</script>