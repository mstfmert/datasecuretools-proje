---
import Layout from '../../layouts/MainLayout.astro';
export const prerender = true;
---
<Layout title="IaC Security Auditor | Terraform & Cloud Security Scanner | DataSecureTools">
  <div style="max-width: 1300px; margin: 40px auto; padding: 0 20px; font-family: 'Inter', sans-serif; color: #0f172a;">
    
    <div style="width: 100%; height: 90px; background: #f8fafc; border: 1px dashed #cbd5e1; border-radius: 12px; margin-bottom: 30px; display: flex; align-items: center; justify-content: center; color: #94a3b8; font-size: 0.8rem;">
      ADVERTISEMENT - GOOGLE ADSENSE
    </div>

    <div style="display: grid; grid-template-columns: 1fr 340px; gap: 40px;">
      <main>
        <div style="background: #ffffff; border-radius: 32px; padding: 50px; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.03); border: 1px solid #f1f5f9;">
          <header style="margin-bottom: 40px;">
            <span style="background: #f0fdf4; color: #16a34a; padding: 6px 14px; border-radius: 100px; font-size: 0.85rem; font-weight: 700;">DEVSECOPS SUITE</span>
            <h1 style="font-size: 2.8rem; font-weight: 900; margin-top: 15px; letter-spacing: -1px;">IaC Security Auditor</h1>
            <p style="color: #64748b; font-size: 1.2rem; margin-top: 10px;">Scan your Terraform, CloudFormation, or K8s YAML for security misconfigurations.</p>
          </header>

          <div style="margin-bottom: 35px;">
            <textarea id="target" placeholder="Paste your Terraform (.tf) or YAML code here..." style="width: 100%; height: 250px; padding: 25px; border-radius: 20px; border: 1px solid #e2e8f0; background: #f8fafc; font-family: 'Fira Code', monospace; font-size: 0.95rem; outline: none; resize: vertical;"></textarea>
          </div>
          
          <button id="runBtn" style="width: 100%; background: #0f172a; color: white; padding: 20px; border-radius: 20px; border: none; font-weight: 800; font-size: 1.2rem; cursor: pointer; transition: 0.3s; box-shadow: 0 10px 15px rgba(0,0,0,0.05);">AUDIT INFRASTRUCTURE</button>

          <div id="results" style="display: none; margin-top: 50px; animation: slideUp 0.6s ease-out;">
            <div id="summary-cards" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 20px; margin-bottom: 30px;">
                </div>

            <div style="background: #0f172a; border-radius: 24px; padding: 40px; border: 1px solid #334155;">
              <span style="color: #64748b; font-size: 0.75rem; font-weight: 800; text-transform: uppercase;">Security Findings Report</span>
              <div id="v-report" style="margin-top: 20px; display: flex; flex-direction: column; gap: 15px;"></div>
            </div>
          </div>
        </div>

        <article style="margin-top: 60px; line-height: 1.8; color: #475569;">
          <h2 style="color: #0f172a; font-size: 1.8rem; font-weight: 800;">Why Infrastructure as Code (IaC) Auditing is Mandatory?</h2>
          <p style="margin-top: 20px;">Securing the cloud starts before the deployment. <strong>Infrastructure as Code Security</strong> ensures that your cloud resources—like S3 buckets, security groups, and IAM roles—are configured following the principle of least privilege. Our <strong>IaC Auditor</strong> helps DevSecOps teams identify "Public-Read" buckets or "0.0.0.0/0" SSH access before they become a production vulnerability.</p>
          
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 30px; margin-top: 30px;">
            <div>
              <h3 style="color: #0f172a; font-size: 1.2rem; font-weight: 700;">Static Analysis (SAST)</h3>
              <p style="font-size: 0.9rem;">By scanning the code statically, we identify risks without needing access to your live cloud environment, ensuring zero data leakage.</p>
            </div>
            <div>
              <h3 style="color: #0f172a; font-size: 1.2rem; font-weight: 700;">Compliance Alignment</h3>
              <p style="font-size: 0.9rem;">Align your infrastructure with CIS Benchmarks and AWS Best Practices by enforcing strict security rules in your templates.</p>
            </div>
          </div>
        </article>
      </main>

      <aside>
        <div style="width: 100%; height: 600px; background: #f8fafc; border: 1px dashed #cbd5e1; border-radius: 24px; margin-bottom: 40px; display: flex; align-items: center; justify-content: center; color: #94a3b8;">
          ADSENSE SKYSCRAPER
        </div>

        <div style="background: #f0fdf4; padding: 30px; border-radius: 32px;">
          <h3 style="font-size: 1.1rem; font-weight: 900; color: #0f172a; margin-bottom: 25px;">Architect Advice</h3>
          <div style="display: flex; flex-direction: column; gap: 20px;">
            <div style="background: white; padding: 20px; border-radius: 18px;">
              <strong style="color: #16a34a; display: block; margin-bottom: 5px; font-size: 0.9rem;">Drift Detection</strong>
              <p style="font-size: 0.8rem; color: #64748b;">Always use IaC to manage cloud resources to prevent 'manual drift' that compromises security.</p>
            </div>
            <div style="background: white; padding: 20px; border-radius: 18px;">
              <strong style="color: #3b82f6; display: block; margin-bottom: 5px; font-size: 0.9rem;">Secret Management</strong>
              <p style="font-size: 0.8rem; color: #64748b;">Never hardcode API keys or passwords in your IaC files. Use AWS Secrets Manager or Vault.</p>
            </div>
          </div>
        </div>
      </aside>
    </div>
  </div>
</Layout>

<style> @keyframes slideUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } } </style>

<script>
  const rules = [
    { n: 'Public S3 Bucket', r: /acl\s*=\s*"public-read"/i, s: 'CRITICAL', d: 'Bucket is publicly readable.' },
    { n: 'Wide Open Security Group', r: /cidr_blocks\s*=\s*\["0\.0\.0\.0\/0"\]/i, s: 'HIGH', d: 'Network access is open to the entire internet.' },
    { n: 'Unencrypted EBS', r: /encrypted\s*=\s*false/i, s: 'MEDIUM', d: 'EBS volumes should be encrypted at rest.' },
    { n: 'Privileged Container', r: /privileged:\s*true/i, s: 'CRITICAL', d: 'Container is running with root-level host access.' },
    { n: 'Insecure Protocol', r: /protocol\s*=\s*"http"/i, s: 'MEDIUM', d: 'Plaintext HTTP detected. Use HTTPS.' }
  ];

  const btn = document.getElementById('runBtn');
  btn?.addEventListener('click', () => {
    const code = (document.getElementById('target') as HTMLTextAreaElement).value;
    if(!code) return alert("Please paste some code to audit.");

    btn.innerText = "RUNNING SECURITY SCAN...";
    
    const findings = [];
    rules.forEach(rule => {
      if(rule.r.test(code)) findings.push(rule);
    });

    const reportDiv = document.getElementById('v-report');
    const summaryDiv = document.getElementById('summary-cards');
    reportDiv.innerHTML = '';
    
    summaryDiv.innerHTML = `
      <div style="background:white; padding:20px; border-radius:18px; border-left:5px solid #10b981;">
        <span style="font-size:0.7rem; font-weight:800; color:#94a3b8;">SCAN STATUS</span>
        <div style="font-weight:800; color:#0f172a; margin-top:5px;">${findings.length > 0 ? 'VULNERABLE' : 'SECURE'}</div>
      </div>
      <div style="background:white; padding:20px; border-radius:18px; border-left:5px solid #ef4444;">
        <span style="font-size:0.7rem; font-weight:800; color:#94a3b8;">TOTAL ISSUES</span>
        <div style="font-weight:800; color:#0f172a; margin-top:5px;">${findings.length}</div>
      </div>
    `;

    if(findings.length === 0) {
      reportDiv.innerHTML = '<div style="color:#10b981; font-family:monospace;">✓ No critical misconfigurations detected in this snippet.</div>';
    } else {
      findings.forEach(f => {
        reportDiv.innerHTML += `
          <div style="background:#1e293b; padding:20px; border-radius:16px; border:1px solid #334155;">
            <div style="display:flex; justify-content:space-between; align-items:center;">
              <strong style="color:#38bdf8; font-size:1rem;">${f.n}</strong>
              <span style="font-size:0.7rem; background:#ef4444; color:white; padding:4px 10px; border-radius:8px; font-weight:900;">${f.s}</span>
            </div>
            <p style="color:#94a3b8; font-size:0.85rem; margin-top:10px;">${f.d}</p>
          </div>
        `;
      });
    }

    document.getElementById('results').style.display = "block";
    btn.innerText = "AUDIT INFRASTRUCTURE";
  });
</script>