---
import Layout from '../../layouts/MainLayout.astro';
export const prerender = true;
---
<Layout title="Advanced WebP Image Optimizer | Client-Side Compression | DataSecureTools">
  <div style="max-width: 1300px; margin: 40px auto; padding: 0 20px; font-family: 'Inter', sans-serif; color: #0f172a;">
    
    <div style="width: 100%; height: 90px; background: #f8fafc; border: 1px dashed #cbd5e1; border-radius: 12px; margin-bottom: 30px; display: flex; align-items: center; justify-content: center; color: #94a3b8; font-size: 0.8rem;">
      ADVERTISEMENT - GOOGLE ADSENSE
    </div>

    <div style="display: grid; grid-template-columns: 1fr 340px; gap: 40px;">
      <main>
        <div style="background: #ffffff; border-radius: 32px; padding: 50px; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.03); border: 1px solid #f1f5f9;">
          <header style="margin-bottom: 40px;">
            <span style="background: #eef2ff; color: #4f46e5; padding: 6px 14px; border-radius: 100px; font-size: 0.85rem; font-weight: 700;">VISUAL OPTIMIZATION</span>
            <h1 style="font-size: 2.8rem; font-weight: 900; margin-top: 15px; letter-spacing: -1px;">Image Optimizer</h1>
            <p style="color: #64748b; font-size: 1.2rem; margin-top: 10px;">Compress and convert images to WebP format instantly in your browser.</p>
          </header>

          <div style="margin-bottom: 35px;">
            <div id="drop-zone" style="width: 100%; height: 200px; background: #f8fafc; border: 2px dashed #cbd5e1; border-radius: 20px; display: flex; align-items: center; justify-content: center; cursor: pointer;">
                <p style="color: #94a3b8; font-size: 1.1rem; font-weight: 600;">Drag & Drop or Click to Upload Image</p>
                <input type="file" id="fileInput" accept="image/jpeg, image/png, image/webp" style="display: none;" />
            </div>
            
            <div style="margin-top: 25px; background: #f8fafc; padding: 20px; border-radius: 20px; border: 1px solid #e2e8f0; display: grid; grid-template-columns: 1fr 120px; gap: 20px; align-items: center;">
                <input type="range" id="quality" min="0.1" max="1.0" step="0.1" value="0.8" style="width: 100%; height: 6px; border-radius: 10px; cursor: pointer;" />
                <span style="font-size: 0.85rem; font-weight: 700; color: #64748b;">Quality: <span id="q-val">80</span>%</span>
            </div>
          </div>
          
          <button id="runBtn" style="width: 100%; background: #0f172a; color: white; padding: 20px; border-radius: 20px; border: none; font-weight: 800; font-size: 1.2rem; cursor: pointer; transition: 0.3s; box-shadow: 0 10px 15px rgba(0,0,0,0.05);">OPTIMIZE IMAGE</button>

          <div id="results" style="display: none; margin-top: 50px; animation: slideUp 0.6s ease-out;">
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; margin-bottom: 40px;">
              <div style="background: #ffffff; padding: 25px; border-radius: 24px; border: 1px solid #f1f5f9; text-align: center;">
                <span style="font-size: 0.75rem; font-weight: 800; color: #94a3b8;">ORIGINAL SIZE</span>
                <div id="v-orig" style="font-size: 1.5rem; font-weight: 800; color: #0f172a; margin-top: 8px;">0 KB</div>
              </div>
              <div style="background: #ffffff; padding: 25px; border-radius: 24px; border: 1px solid #f1f5f9; text-align: center;">
                <span style="font-size: 0.75rem; font-weight: 800; color: #94a3b8;">OPTIMIZED SIZE</span>
                <div id="v-opt" style="font-size: 1.5rem; font-weight: 800; color: #10b981; margin-top: 8px;">0 KB</div>
              </div>
              <div style="background: #ffffff; padding: 25px; border-radius: 24px; border: 1px solid #f1f5f9; text-align: center;">
                <span style="font-size: 0.75rem; font-weight: 800; color: #94a3b8;">TOTAL SAVING</span>
                <div id="v-saving" style="font-size: 1.5rem; font-weight: 800; color: #3b82f6; margin-top: 8px;">0%</div>
              </div>
            </div>

            <div style="background: #0f172a; border-radius: 24px; padding: 40px; border: 1px solid #334155;">
              <span style="color: #64748b; font-size: 0.75rem; font-weight: 800; text-transform: uppercase;">Technical Compression Log</span>
              <div id="v-report" style="font-family: 'Fira Code', monospace; color: #38bdf8; font-size: 0.95rem; margin-top: 20px; line-height: 1.8;"></div>
            </div>
          </div>
        </div>

        <article style="margin-top: 60px; line-height: 1.8; color: #475569;">
          <h2 style="color: #0f172a; font-size: 1.8rem; font-weight: 800;">Image Optimization & Core Web Vitals (LCP)</h2>
          <p style="margin-top: 20px;">Images often account for the bulk of a webpage's weight. Our <strong>Image Optimizer</strong> leverages the native **Canvas API** of your browser to perform lossy compression on PNG and JPEG files, converting them to the highly efficient **WebP format**. This directly optimizes your **Largest Contentful Paint (LCP)**, one of the three critical Core Web Vitals, ensuring that search engines recognize your site as fast and user-friendly.</p>
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 30px; margin-top: 30px;">
            <div>
              <h3 style="color: #0f172a; font-size: 1.2rem; font-weight: 700;">WebP Converter</h3>
              <p style="font-size: 0.9rem;">By converting assets to WebP, you maintain the transparency of PNG while getting the high compression ratios of JPEG, all within a smaller footprint.</p>
            </div>
            <div>
              <h3 style="color: #0f172a; font-size: 1.2rem; font-weight: 700;">Browser Caching</h3>
              <p style="font-size: 0.9rem;">Smaller images reduce bandwidth consumption and lead to faster load times, especially for mobile users on cellular networks.</p>
            </div>
          </div>
        </article>
      </main>

      <aside>
        <div style="width: 100%; height: 600px; background: #f8fafc; border: 1px dashed #cbd5e1; border-radius: 24px; margin-bottom: 40px; display: flex; align-items: center; justify-content: center; color: #94a3b8;">
          ADSENSE SKYSCRAPER
        </div>

        <div style="background: #f1f5f9; padding: 30px; border-radius: 32px;">
          <h3 style="font-size: 1.1rem; font-weight: 900; color: #0f172a; margin-bottom: 25px;">Perf Strategy</h3>
          <div style="display: flex; flex-direction: column; gap: 20px;">
            <div style="background: white; padding: 20px; border-radius: 18px; box-shadow: 0 4px 6px rgba(0,0,0,0.02);">
              <strong style="color: #4f46e5; display: block; margin-bottom: 5px; font-size: 0.9rem;">Serve Images in Next-Gen Formats</strong>
              <p style="font-size: 0.8rem; color: #64748b;">Follow Google's audit recommendation by strictly using WebP or AVIF for all above-the-fold content.</p>
            </div>
            <div style="background: white; padding: 20px; border-radius: 18px; box-shadow: 0 4px 6px rgba(0,0,0,0.02);">
              <strong style="color: #10b981; display: block; margin-bottom: 5px; font-size: 0.9rem;">Proper Sizing</strong>
              <p style="font-size: 0.8rem; color: #64748b;">Combine compression with proper explicit dimensions to reduce CLS and speed up rendering.</p>
            </div>
          </div>
        </div>
      </aside>
    </div>
  </div>
</Layout>

<style> @keyframes slideUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } } </style>

<script>
  const fileInput = document.getElementById('fileInput');
  const dropZone = document.getElementById('drop-zone');
  const quality = document.getElementById('quality');
  let selectedFile = null;

  dropZone?.addEventListener('click', () => fileInput.click());
  
  dropZone?.addEventListener('dragover', (e) => {
    e.preventDefault();
    dropZone.style.borderColor = "#4f46e5";
    dropZone.style.background = "#eef2ff";
  });

  dropZone?.addEventListener('dragleave', () => {
    dropZone.style.borderColor = "#cbd5e1";
    dropZone.style.background = "#f8fafc";
  });

  dropZone?.addEventListener('drop', (e) => {
    e.preventDefault();
    dropZone.style.borderColor = "#cbd5e1";
    dropZone.style.background = "#f8fafc";
    selectedFile = e.dataTransfer.files[0];
    dropZone.querySelector('p').innerText = "File Selected: " + selectedFile.name;
  });

  fileInput?.addEventListener('change', (e) => {
    selectedFile = e.target.files[0];
    dropZone.querySelector('p').innerText = "File Selected: " + selectedFile.name;
  });

  quality?.addEventListener('input', (e) => {
    document.getElementById('q-val').innerText = Math.round(e.target.value * 100);
  });

  const btn = document.getElementById('runBtn');
  btn?.addEventListener('click', () => {
    if(!selectedFile) return alert("Please upload an image first.");

    btn.innerText = "OPTIMIZING IMAGE...";
    btn.disabled = true;

    const reader = new FileReader();
    reader.onload = (e) => {
      const img = new Image();
      img.onload = () => {
        const canvas = document.createElement('canvas');
        canvas.width = img.width;
        canvas.height = img.height;
        const ctx = canvas.getContext('2d');
        ctx.drawImage(img, 0, 0);

        // Saf JavaScript ile WebP formatına sıkıştırma motoru
        const qVal = parseFloat(quality.value);
        const webpDataUrl = canvas.toDataURL('image/webp', qVal);
        
        const optimizedSize = Math.round(webpDataUrl.length * 0.75); // DataURL size to bytes
        const originalSize = selectedFile.size;
        const saving = Math.round((1 - (optimizedSize / originalSize)) * 100);

        document.getElementById('v-orig').innerText = (originalSize / 1024).toFixed(2) + " KB";
        document.getElementById('v-opt').innerText = (optimizedSize / 1024).toFixed(2) + " KB";
        document.getElementById('v-saving').innerText = (saving > 0 ? saving : 0) + "%";

        document.getElementById('v-report').innerHTML = `
          > Target Format: WebP (Next-Gen)<br>
          > Compression Quality: ${qVal * 100}%<br>
          > Original File Size: ${originalSize.toLocaleString()} bytes<br>
          > Optimized File Size: ${optimizedSize.toLocaleString()} bytes<br>
          > Engine Status: Client-side success
        `;

        document.getElementById('results').style.display = "block";
        
        // İndirme linkini oluştur (Premium Özellik)
        let downloadLink = document.getElementById('dl-link');
        if(!downloadLink) {
           downloadLink = document.createElement('a');
           downloadLink.id = 'dl-link';
           downloadLink.style.cssText = "display:inline-block; margin-top:20px; color:#3b82f6; font-weight:700;";
           downloadLink.innerText = "Download Optimized Image (WebP)";
           document.getElementById('v-report').parentNode.appendChild(downloadLink);
        }
        downloadLink.href = webpDataUrl;
        downloadLink.download = "datasecuretools-optimized-" + selectedFile.name.split('.')[0] + ".webp";

      };
      img.src = e.target.result;
    };
    reader.readAsDataURL(selectedFile);
    
    btn.innerText = "OPTIMIZE IMAGE";
    btn.disabled = false;
  });
</script>