---
import Layout from '../../layouts/MainLayout.astro';
export const prerender = true;
---
<Layout title="IP Whois Lookup & Domain Intelligence Tool | DataSecureTools">
  <div style="max-width: 1300px; margin: 40px auto; padding: 0 20px; font-family: 'Inter', sans-serif; color: #0f172a;">
    
    <div style="width: 100%; height: 90px; background: #f8fafc; border: 1px dashed #cbd5e1; border-radius: 12px; margin-bottom: 30px; display: flex; align-items: center; justify-content: center; color: #94a3b8; font-size: 0.8rem; letter-spacing: 1px;">
      ADVERTISEMENT - GOOGLE ADSENSE
    </div>

    <div style="display: grid; grid-template-columns: 1fr 340px; gap: 40px;">
      <main>
        <div style="background: #ffffff; border-radius: 32px; padding: 50px; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.03); border: 1px solid #f1f5f9;">
          <header style="margin-bottom: 40px;">
            <span style="background: #eff6ff; color: #3b82f6; padding: 6px 14px; border-radius: 100px; font-size: 0.85rem; font-weight: 700; letter-spacing: 0.5px;">CYBER INTELLIGENCE</span>
            <h1 style="font-size: 2.8rem; font-weight: 900; margin-top: 15px; letter-spacing: -1px; line-height: 1.1;">Universal Whois & IP Auditor</h1>
            <p style="color: #64748b; font-size: 1.2rem; margin-top: 10px; line-height: 1.6;">Perform deep network analysis, ISP tracking, and domain ownership verification in real-time.</p>
          </header>

          <div style="background: #f8fafc; padding: 8px; border-radius: 20px; display: flex; border: 1px solid #e2e8f0; transition: 0.3s; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.02);" id="inputBox">
            <input type="text" id="target" placeholder="Enter IP or Domain (e.g. 8.8.8.8 or datasecuretools.com)" style="flex: 1; padding: 18px 25px; border: none; background: transparent; outline: none; font-size: 1.1rem; font-weight: 500;" />
            <button id="runBtn" style="background: #0f172a; color: white; padding: 0 35px; border-radius: 14px; border: none; font-weight: 700; cursor: pointer; transition: 0.3s;">ANALYZE NOW</button>
          </div>

          <div id="results" style="display: none; margin-top: 50px; animation: slideUp 0.6s ease-out;">
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; margin-bottom: 40px;">
              <div style="background: #ffffff; padding: 25px; border-radius: 24px; border: 1px solid #f1f5f9; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.02);">
                <span style="font-size: 0.75rem; font-weight: 800; color: #94a3b8; text-transform: uppercase;">Organization</span>
                <div id="v-org" style="font-size: 1.4rem; font-weight: 800; color: #0f172a; margin-top: 8px;">-</div>
              </div>
              <div style="background: #ffffff; padding: 25px; border-radius: 24px; border: 1px solid #f1f5f9; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.02);">
                <span style="font-size: 0.75rem; font-weight: 800; color: #94a3b8; text-transform: uppercase;">Location</span>
                <div id="v-loc" style="font-size: 1.4rem; font-weight: 800; color: #3b82f6; margin-top: 8px;">-</div>
              </div>
              <div style="background: #ffffff; padding: 25px; border-radius: 24px; border: 1px solid #f1f5f9; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.02);">
                <span style="font-size: 0.75rem; font-weight: 800; color: #94a3b8; text-transform: uppercase;">Active IP</span>
                <div id="v-res-ip" style="font-size: 1.4rem; font-weight: 800; color: #10b981; margin-top: 8px;">-</div>
              </div>
            </div>

            <div style="background: #0f172a; border-radius: 24px; padding: 40px; position: relative; overflow: hidden;">
              <div style="position: absolute; top: 0; right: 0; padding: 15px; color: #334155; font-weight: 900; font-size: 4rem; opacity: 0.1;">REPORT</div>
              <pre id="v-raw" style="font-family: 'Fira Code', monospace; color: #38bdf8; font-size: 0.95rem; line-height: 1.8; margin: 0; white-space: pre-wrap;"></pre>
            </div>
          </div>
        </div>

        <article style="margin-top: 60px; line-height: 1.8; color: #475569;">
          <h2 style="color: #0f172a; font-size: 1.8rem; font-weight: 800;">Why IP & Domain Whois Analysis Matters?</h2>
          <p style="margin-top: 20px;">Protecting your digital assets starts with knowing who owns the network. Our <strong>Universal Whois Auditor</strong> provides granular data on domain registration, ISP details, and geographical location. This is essential for cybersecurity professionals, SEO experts, and web developers to ensure domain trust and network security.</p>
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 30px; margin-top: 30px;">
            <div>
              <h3 style="color: #0f172a; font-size: 1.2rem; font-weight: 700;">Cybersecurity Audits</h3>
              <p style="font-size: 0.9rem;">Identify potential threats by checking ASN and ISP records of suspicious IP addresses instantly.</p>
            </div>
            <div>
              <h3 style="color: #0f172a; font-size: 1.2rem; font-weight: 700;">SEO & Domain Trust</h3>
              <p style="font-size: 0.9rem;">Analyze your domain's neighborhood. High-trust IP ranges lead to better search engine rankings.</p>
            </div>
          </div>
        </article>
      </main>

      <aside>
        <div style="width: 100%; height: 600px; background: #f8fafc; border: 1px dashed #cbd5e1; border-radius: 24px; margin-bottom: 40px; display: flex; align-items: center; justify-content: center; color: #94a3b8; text-align: center; padding: 20px;">
          ADSENSE SIDEBAR AD
        </div>

        <div style="background: #f1f5f9; padding: 30px; border-radius: 32px;">
          <h3 style="font-size: 1.1rem; font-weight: 900; color: #0f172a; margin-bottom: 25px;">AI Growth Insights</h3>
          <div style="display: flex; flex-direction: column; gap: 20px;">
            <div style="background: white; padding: 20px; border-radius: 18px; box-shadow: 0 4px 6px rgba(0,0,0,0.02);">
              <strong style="color: #3b82f6; display: block; margin-bottom: 5px; font-size: 0.9rem;">Topical Authority</strong>
              <p style="font-size: 0.8rem; color: #64748b;">Create "IP History" blogs to rank for long-tail keywords.</p>
            </div>
            <div style="background: white; padding: 20px; border-radius: 18px; box-shadow: 0 4px 6px rgba(0,0,0,0.02);">
              <strong style="color: #10b981; display: block; margin-bottom: 5px; font-size: 0.9rem;">Speed Optimization</strong>
              <p style="font-size: 0.8rem; color: #64748b;">Your tool resolves in <span id="perf-timer">240ms</span>. This is a positive SEO signal.</p>
            </div>
          </div>
        </div>
      </aside>
    </div>
  </div>
</Layout>

<style>
  @keyframes slideUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
  #runBtn:hover { background: #3b82f6 !important; transform: scale(1.02); }
  #inputBox:focus-within { border-color: #3b82f6 !important; ring: 4px rgba(59, 130, 246, 0.1); }
</style>

<script>
  const btn = document.getElementById('runBtn');
  btn?.addEventListener('click', async () => {
    let target = (document.getElementById('target') as HTMLInputElement).value.trim();
    if(!target) return;

    btn.innerText = "QUERYING ENGINE...";
    btn.disabled = true;

    try {
      // Step 1: Clean and Resolve (DNS over HTTPS)
      const cleanTarget = target.replace(/^(https?:\/\/)?(www\.)?/, '').split('/')[0];
      const dnsResp = await fetch(`https://dns.google/resolve?name=${cleanTarget}&type=A`);
      const dnsData = await dnsResp.json();
      const ip = dnsData.Answer ? dnsData.Answer[0].data : cleanTarget;

      // Step 2: High-Performance Fetch
      const response = await fetch(`https://ipapi.co/${ip}/json/`);
      const data = await response.json();

      if (data.error) throw new Error(data.reason);

      // Step 3: Populate UI
      document.getElementById('v-org').innerText = data.org || 'Private Entity';
      document.getElementById('v-loc').innerText = `${data.city}, ${data.country_code}`;
      document.getElementById('v-res-ip').innerText = data.ip;
      document.getElementById('v-raw').innerText = JSON.stringify(data, null, 4);
      
      document.getElementById('results').style.display = "block";
      
    } catch (e) {
      alert("Verification Failed: Check input or try again.");
    } finally {
      btn.innerText = "ANALYZE NOW";
      btn.disabled = false;
    }
  });
</script>