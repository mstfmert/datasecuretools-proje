---
import Layout from '../../layouts/MainLayout.astro';
export const prerender = true;
---
<Layout title="Keyword Density Checker | On-Page SEO Content Audit | DataSecureTools">
  <div style="max-width: 1400px; margin: 40px auto; padding: 0 20px; font-family: 'Inter', sans-serif; color: #0f172a;">
    
    <div style="width: 100%; height: 90px; background: #f8fafc; border: 1px dashed #cbd5e1; border-radius: 12px; margin-bottom: 30px; display: flex; align-items: center; justify-content: center; color: #94a3b8; font-size: 0.8rem;">
      ADVERTISEMENT - GOOGLE ADSENSE LEADERBOARD
    </div>

    <div style="display: grid; grid-template-columns: 280px 1fr 340px; gap: 30px;">
      
      <aside style="background: #ffffff; border-radius: 24px; padding: 25px; border: 1px solid #f1f5f9; height: fit-content;">
        <h3 style="font-size: 0.9rem; font-weight: 800; color: #0f172a; margin-bottom: 20px; text-transform: uppercase; letter-spacing: 1px;">Network Tools</h3>
        <ul style="list-style: none; padding: 0; font-size: 0.9rem; display: flex; flex-direction: column; gap: 12px;">
            <li><a href="/tools/dns-lookup" style="text-decoration: none; color: #64748b; font-weight: 600;">DNS Lookup</a></li>
            <li><a href="/tools/port-scanner" style="text-decoration: none; color: #64748b; font-weight: 600;">Port Scanner</a></li>
            <li><a href="/tools/subnet-calc" style="text-decoration: none; color: #64748b; font-weight: 600;">Subnet Calculator</a></li>
            <li><a href="/tools/seo-analyzer" style="text-decoration: none; color: #0f172a; font-weight: 800;">SEO Analyzer</a></li>
            <li><a href="/tools/security-auditor" style="text-decoration: none; color: #64748b; font-weight: 600;">Security Auditor</a></li>
        </ul>
      </aside>

      <main>
        <div style="background: #ffffff; border-radius: 32px; padding: 45px; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.03); border: 1px solid #f1f5f9;">
          <header style="margin-bottom: 35px;">
            <span style="background: #fdf2f8; color: #db2777; padding: 6px 14px; border-radius: 100px; font-size: 0.8rem; font-weight: 700;">CONTENT INTELLIGENCE</span>
            <h1 style="font-size: 2.5rem; font-weight: 900; margin-top: 15px; letter-spacing: -1px;">Keyword Density Checker</h1>
            <p style="color: #64748b; font-size: 1.1rem; margin-top: 10px;">Audit your content's keyword distribution to avoid SEO penalties and improve rankings.</p>
          </header>

          <div style="margin-bottom: 30px;">
            <textarea id="target" placeholder="Paste your article or content here..." style="width: 100%; height: 200px; padding: 20px; border-radius: 18px; border: 1px solid #e2e8f0; background: #f8fafc; font-family: inherit; font-size: 1rem; outline: none; resize: vertical;"></textarea>
          </div>
          
          <button id="runBtn" style="width: 100%; background: #0f172a; color: white; padding: 18px; border-radius: 16px; border: none; font-weight: 800; font-size: 1.1rem; cursor: pointer; transition: 0.3s;">ANALYZE DENSITY</button>

          <div id="results" style="display: none; margin-top: 40px; animation: slideUp 0.6s ease-out;">
            <div id="v-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 15px; margin-bottom: 30px;">
                </div>
          </div>
        </div>

        <article style="margin-top: 50px; line-height: 1.8; color: #475569;">
          <h2 style="color: #0f172a; font-size: 1.6rem; font-weight: 800;">The Balance of Keyword Optimization</h2>
          <p style="margin-top: 15px;">Maintaining the correct <strong>Keyword Density</strong> is a critical skill in modern on-page SEO. While keywords help search engines identify the topic of your page, excessive repetition—known as <strong>Keyword Stuffing</strong>—can lead to severe algorithmic penalties. Our analyzer provides a surgical breakdown of your content, helping you stay within the optimal 1-2% range for primary keywords while ensuring your <strong>LSI (Latent Semantic Indexing)</strong> distribution is natural and effective.</p>
          
        </article>
      </main>

      <aside>
        <div style="width: 100%; height: 400px; background: #f8fafc; border: 1px dashed #cbd5e1; border-radius: 24px; margin-bottom: 30px; display: flex; align-items: center; justify-content: center; color: #94a3b8; text-align: center;">
          ADSENSE SKYSCRAPER
        </div>

        <div style="background: #fdf2f8; padding: 25px; border-radius: 24px; margin-bottom: 20px;">
            <strong style="color: #db2777; display: block; margin-bottom: 8px; font-size: 0.9rem;">NLP Focus</strong>
            <p style="font-size: 0.8rem; color: #64748b;">Google uses Natural Language Processing. Focus on context rather than exact matches to win in 2026.</p>
        </div>

        <div style="background: #eef2ff; padding: 25px; border-radius: 24px;">
            <strong style="color: #4f46e5; display: block; margin-bottom: 8px; font-size: 0.9rem;">Density Range</strong>
            <p style="font-size: 0.8rem; color: #64748b;">Keep your primary keyword below 2.5% to avoid 'over-optimization' triggers.</p>
        </div>
      </aside>

    </div>
  </div>
</Layout>

<style> @keyframes slideUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } } </style>

<script>
  const btn = document.getElementById('runBtn');
  btn?.addEventListener('click', () => {
    const text = (document.getElementById('target') as HTMLTextAreaElement).value.trim();
    if(!text) return alert("Please paste some content.");

    const words = text.toLowerCase().match(/\b(\w+)\b/g);
    const total = words.length;
    const freq = {};
    
    words.forEach(w => { if(w.length > 3) freq[w] = (freq[w] || 0) + 1; });
    
    const sorted = Object.entries(freq).sort((a:any, b:any) => b[1] - a[1]).slice(0, 8);
    
    const grid = document.getElementById('v-grid');
    grid.innerHTML = sorted.map(([word, count]:any) => {
        const percent = ((count / total) * 100).toFixed(1);
        return `
            <div style="background:#f8fafc; padding:20px; border-radius:18px; border:1px solid #e2e8f0; text-align:center;">
                <div style="font-weight:800; color:#0f172a; font-size:1rem;">${word}</div>
                <div style="color:#db2777; font-weight:900; font-size:1.2rem; margin-top:5px;">${percent}%</div>
                <div style="font-size:0.7rem; color:#94a3b8; margin-top:3px;">${count} times</div>
            </div>
        `;
      }).join('');

    document.getElementById('results').style.display = "block";
  });
</script>