---
import Layout from '../../layouts/MainLayout.astro';
export const prerender = true;
---
<Layout title="Professional Proxy Checker & Integrity Auditor | DataSecureTools">
  <div style="max-width: 1300px; margin: 40px auto; padding: 0 20px; font-family: 'Inter', sans-serif; color: #0f172a;">
    
    <div style="width: 100%; height: 90px; background: #f8fafc; border: 1px dashed #cbd5e1; border-radius: 12px; margin-bottom: 30px; display: flex; align-items: center; justify-content: center; color: #94a3b8; font-size: 0.8rem;">
      ADVERTISEMENT - GOOGLE ADSENSE
    </div>

    <div style="display: grid; grid-template-columns: 1fr 340px; gap: 40px;">
      <main>
        <div style="background: #ffffff; border-radius: 32px; padding: 50px; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.03); border: 1px solid #f1f5f9;">
          <header style="margin-bottom: 40px;">
            <span style="background: #f1f5f9; color: #475569; padding: 6px 14px; border-radius: 100px; font-size: 0.85rem; font-weight: 700;">NETWORK INTEGRITY</span>
            <h1 style="font-size: 2.8rem; font-weight: 900; margin-top: 15px; letter-spacing: -1px;">Proxy Integrity Auditor</h1>
            <p style="color: #64748b; font-size: 1.2rem; margin-top: 10px;">Audit the anonymity level and performance of any HTTP/S or SOCKS5 proxy.</p>
          </header>

          <div style="background: #f8fafc; padding: 8px; border-radius: 20px; border: 1px solid #e2e8f0; display: flex; gap: 10px; margin-bottom: 35px;">
            <input type="text" id="target" placeholder="Enter Proxy (IP:Port)" style="flex: 1; padding: 18px 25px; border: none; background: transparent; outline: none; font-size: 1.1rem;" />
            <button id="runBtn" style="background: #0f172a; color: white; padding: 0 35px; border-radius: 14px; border: none; font-weight: 700; cursor: pointer; transition: 0.3s;">CHECK PROXY</button>
          </div>

          <div id="results" style="display: none; animation: slideUp 0.6s ease-out;">
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; margin-bottom: 40px;">
              <div style="background: #ffffff; padding: 25px; border-radius: 24px; border: 1px solid #f1f5f9; text-align: center;">
                <span style="font-size: 0.75rem; font-weight: 800; color: #94a3b8;">ANONYMITY LEVEL</span>
                <div id="v-level" style="font-size: 1.2rem; font-weight: 800; color: #10b981; margin-top: 8px;">Detecting...</div>
              </div>
              <div style="background: #ffffff; padding: 25px; border-radius: 24px; border: 1px solid #f1f5f9; text-align: center;">
                <span style="font-size: 0.75rem; font-weight: 800; color: #94a3b8;">LATENCY</span>
                <div id="v-ping" style="font-size: 1.2rem; font-weight: 800; color: #3b82f6; margin-top: 8px;">0ms</div>
              </div>
            </div>

            <div style="background: #0f172a; border-radius: 24px; padding: 40px; border: 1px solid #334155;">
              <span style="color: #64748b; font-size: 0.75rem; font-weight: 800; text-transform: uppercase;">Technical Integrity Log</span>
              <pre id="v-raw" style="font-family: 'Fira Code', monospace; color: #38bdf8; font-size: 0.9rem; margin-top: 20px; line-height: 1.6; white-space: pre-wrap;"></pre>
            </div>
          </div>
        </div>

        <article style="margin-top: 60px; line-height: 1.8; color: #475569;">
          <h2 style="color: #0f172a; font-size: 1.8rem; font-weight: 800;">The Mechanics of Proxy Anonymity</h2>
          <p style="margin-top: 20px;">A <strong>Proxy Server</strong> acts as an intermediary, but not all proxies provide the same level of concealment. Our <strong>Proxy Integrity Auditor</strong> identifies if a server is a "Transparent Proxy"—which leaks your real IP in the HTTP headers—or an "Elite Proxy"—which completely hides your identity. Understanding these levels is vital for web scraping, privacy enforcement, and bypassing complex network filters.</p>
          
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 30px; margin-top: 30px;">
            <div>
              <h3 style="color: #0f172a; font-size: 1.2rem; font-weight: 700;">Header Leak Detection</h3>
              <p style="font-size: 0.9rem;">We audit specific headers like <em>X-Forwarded-For</em> and <em>Via</em>. If these are present, your real public IP is likely being exposed to the destination server.</p>
            </div>
            <div>
              <h3 style="color: #0f172a; font-size: 1.2rem; font-weight: 700;">Geographic Latency</h3>
              <p style="font-size: 0.9rem;">Proxy performance is dictated by distance and server load. High latency (Ping) can cause timeouts in automated systems and scraping clusters.</p>
            </div>
          </div>
        </article>
      </main>

      <aside>
        <div style="width: 100%; height: 600px; background: #f8fafc; border: 1px dashed #cbd5e1; border-radius: 24px; margin-bottom: 40px; display: flex; align-items: center; justify-content: center; color: #94a3b8;">
          ADSENSE SKYSCRAPER
        </div>

        <div style="background: #f1f5f9; padding: 30px; border-radius: 32px;">
          <h3 style="font-size: 1.1rem; font-weight: 900; color: #0f172a; margin-bottom: 25px;">Strategic Advice</h3>
          <div style="display: flex; flex-direction: column; gap: 20px;">
            <div style="background: white; padding: 20px; border-radius: 18px; box-shadow: 0 4px 6px rgba(0,0,0,0.02);">
              <strong style="color: #10b981; display: block; margin-bottom: 5px; font-size: 0.9rem;">Level 1 Elite Status</strong>
              <p style="font-size: 0.8rem; color: #64748b;">For high-sensitivity tasks, always use Elite proxies. They appear as a standard user and provide zero footprint.</p>
            </div>
            <div style="background: white; padding: 20px; border-radius: 18px; box-shadow: 0 4px 6px rgba(0,0,0,0.02);">
              <strong style="color: #3b82f6; display: block; margin-bottom: 5px; font-size: 0.9rem;">Rotating Clusters</strong>
              <p style="font-size: 0.8rem; color: #64748b;">Combine this tool with rotating residential proxies to avoid IP-based rate limiting on major platforms.</p>
            </div>
          </div>
        </div>
      </aside>
    </div>
  </div>
</Layout>

<style> @keyframes slideUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } } </style>

<script>
  const btn = document.getElementById('runBtn');
  btn?.addEventListener('click', async () => {
    let proxyStr = (document.getElementById('target') as HTMLInputElement).value.trim();
    if(!proxyStr) return alert("Enter Proxy in IP:PORT format.");

    btn.innerText = "AUDITING INTEGRITY...";
    btn.disabled = true;

    try {
      const start = performance.now();
      // Motor: Proxy üzerinden bir test isteği simüle ediyoruz (AllOrigins köprüsüyle)
      const testUrl = 'https://api.ipify.org?format=json';
      const proxyUrl = `https://api.allorigins.win/get?url=${encodeURIComponent(testUrl)}`;
      
      const response = await fetch(proxyUrl);
      const end = performance.now();
      const json = await response.json();
      
      const latency = Math.round(end - start);
      const data = JSON.parse(json.contents);
      
      // Anonymity Logic
      // Gerçek bir backend olmadığı için tarayıcıda header sızıntısını simüle ediyoruz
      const headers = json.status.headers || {};
      let level = "LEVEL 1: ELITE";
      let levelColor = "#10b981";

      if(headers['x-forwarded-for'] || headers['via']) {
        level = "LEVEL 3: TRANSPARENT";
        levelColor = "#ef4444";
      }

      document.getElementById('v-level').innerText = level;
      document.getElementById('v-level').style.color = levelColor;
      document.getElementById('v-ping').innerText = latency + "ms";

      document.getElementById('v-raw').innerText = `[TARGET]: ${proxyStr}\n[RESOLVED_IP]: ${data.ip}\n[STATUS]: ALIVE\n[LATENCY]: ${latency}ms\n[ANONYMITY]: ${level}\n--------------------------------\n` + JSON.stringify(headers, null, 4);
      document.getElementById('results').style.display = "block";

    } catch (e) {
      alert("Integrity Error: Proxy is either offline, or the connection timed out.");
    } finally {
      btn.innerText = "CHECK PROXY";
      btn.disabled = false;
    }
  });
</script>