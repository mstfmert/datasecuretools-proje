---
import Layout from '../../layouts/MainLayout.astro';
export const prerender = true;
---
<Layout title="Random IP Generator | Bulk IPv4 Address Creator | DataSecureTools">
  <div style="max-width: 1300px; margin: 40px auto; padding: 0 20px; font-family: 'Inter', sans-serif; color: #0f172a;">
    
    <div style="width: 100%; height: 90px; background: #f8fafc; border: 1px dashed #cbd5e1; border-radius: 12px; margin-bottom: 30px; display: flex; align-items: center; justify-content: center; color: #94a3b8; font-size: 0.8rem;">
      ADVERTISEMENT - GOOGLE ADSENSE
    </div>

    <div style="display: grid; grid-template-columns: 1fr 340px; gap: 40px;">
      <main>
        <div style="background: #ffffff; border-radius: 32px; padding: 50px; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.03); border: 1px solid #f1f5f9;">
          <header style="margin-bottom: 40px;">
            <span style="background: #eef2ff; color: #4f46e5; padding: 6px 14px; border-radius: 100px; font-size: 0.85rem; font-weight: 700;">DATA SYNTHESIS</span>
            <h1 style="font-size: 2.8rem; font-weight: 900; margin-top: 15px; letter-spacing: -1px;">Random IP Generator</h1>
            <p style="color: #64748b; font-size: 1.2rem; margin-top: 10px;">Generate high-quality, valid IPv4 addresses for testing and simulation purposes.</p>
          </header>

          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 35px;">
            <div style="background: #f8fafc; padding: 20px; border-radius: 20px; border: 1px solid #e2e8f0;">
               <label style="font-size: 0.8rem; font-weight: 800; color: #94a3b8; display: block; margin-bottom: 10px;">QUANTITY</label>
               <input type="number" id="qty" value="10" min="1" max="100" style="width: 100%; border: none; background: transparent; font-size: 1.2rem; font-weight: 700; outline: none;" />
            </div>
            <div style="background: #f8fafc; padding: 20px; border-radius: 20px; border: 1px solid #e2e8f0;">
               <label style="font-size: 0.8rem; font-weight: 800; color: #94a3b8; display: block; margin-bottom: 10px;">IP CLASS</label>
               <select id="class" style="width: 100%; border: none; background: transparent; font-size: 1.1rem; font-weight: 600; outline: none; cursor: pointer;">
                  <option value="any">Any (Global)</option>
                  <option value="public">Public Only</option>
                  <option value="private">Private (LAN)</option>
               </select>
            </div>
          </div>
          
          <button id="runBtn" style="width: 100%; background: #0f172a; color: white; padding: 20px; border-radius: 20px; border: none; font-weight: 800; font-size: 1.2rem; cursor: pointer; transition: 0.3s; box-shadow: 0 10px 15px rgba(0,0,0,0.05);">GENERATE IP LIST</button>

          <div id="results" style="display: none; margin-top: 50px; animation: slideUp 0.6s ease-out;">
            <div style="background: #0f172a; border-radius: 24px; padding: 40px; position: relative;">
              <button id="copyBtn" style="position: absolute; top: 20px; right: 20px; background: #334155; color: white; padding: 8px 15px; border-radius: 10px; border: none; font-size: 0.8rem; cursor: pointer;">Copy List</button>
              <span style="color: #64748b; font-size: 0.75rem; font-weight: 800; text-transform: uppercase;">Generated IPv4 Intelligence</span>
              <div id="v-list" style="font-family: 'Fira Code', monospace; color: #38bdf8; font-size: 1.1rem; margin-top: 30px; line-height: 2; display: grid; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 10px;"></div>
            </div>
          </div>
        </div>

        <article style="margin-top: 60px; line-height: 1.8; color: #475569;">
          <h2 style="color: #0f172a; font-size: 1.8rem; font-weight: 800;">Why Use a Random IP Generator for Testing?</h2>
          <p style="margin-top: 20px;">In the world of network engineering and cybersecurity, testing systems with diverse data inputs is vital. A <strong>Random IP Generator</strong> allows developers to create realistic datasets for stress testing firewalls, validating access control lists (ACLs), or simulating global traffic patterns. Our tool ensures that the generated <strong>IPv4 addresses</strong> adhere to standard networking rules, differentiating between public routable IPs and private network ranges.</p>
          
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 30px; margin-top: 30px;">
            <div>
              <h3 style="color: #0f172a; font-size: 1.2rem; font-weight: 700;">Simulation & Sandbox</h3>
              <p style="font-size: 0.9rem;">Fill your test databases with valid IP structures to ensure your geo-targeting logic or logging systems handle edge cases correctly.</p>
            </div>
            <div>
              <h3 style="color: #0f172a; font-size: 1.2rem; font-weight: 700;">Security Hardening</h3>
              <p style="font-size: 0.9rem;">Use generated IP lists to test firewall rules and verify that your infrastructure correctly identifies and filters different IP classes.</p>
            </div>
          </div>
        </article>
      </main>

      <aside>
        <div style="width: 100%; height: 600px; background: #f8fafc; border: 1px dashed #cbd5e1; border-radius: 24px; margin-bottom: 40px; display: flex; align-items: center; justify-content: center; color: #94a3b8;">
          ADSENSE SKYSCRAPER
        </div>

        <div style="background: #f5f3ff; padding: 30px; border-radius: 32px;">
          <h3 style="font-size: 1.1rem; font-weight: 900; color: #0f172a; margin-bottom: 25px;">Pro Developer Advice</h3>
          <div style="display: flex; flex-direction: column; gap: 20px;">
            <div style="background: white; padding: 20px; border-radius: 18px;">
              <strong style="color: #4f46e5; display: block; margin-bottom: 5px; font-size: 0.9rem;">Reserved Ranges</strong>
              <p style="font-size: 0.8rem; color: #64748b;">Remember that ranges like 127.x.x.x are reserved for loopback and will never appear in public routing tables.</p>
            </div>
            <div style="background: white; padding: 20px; border-radius: 18px;">
              <strong style="color: #10b981; display: block; margin-bottom: 5px; font-size: 0.9rem;">Stress Testing</strong>
              <p style="font-size: 0.8rem; color: #64748b;">Combine this tool with our Port Scanner to simulate audits on various network nodes.</p>
            </div>
          </div>
        </div>
      </aside>
    </div>
  </div>
</Layout>

<style> @keyframes slideUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } } </style>

<script>
  function getRandomByte() { return Math.floor(Math.random() * 256); }

  function generateIP(type) {
    let ip = [getRandomByte(), getRandomByte(), getRandomByte(), getRandomByte()];
    
    if (type === 'private') {
      const privateBlocks = [
        [10, getRandomByte(), getRandomByte(), getRandomByte()],
        [172, Math.floor(Math.random() * (31 - 16 + 1)) + 16, getRandomByte(), getRandomByte()],
        [192, 168, getRandomByte(), getRandomByte()]
      ];
      ip = privateBlocks[Math.floor(Math.random() * privateBlocks.length)];
    } else if (type === 'public') {
      // Exclude private and reserved ranges
      while (
        ip[0] === 10 || 
        (ip[0] === 172 && ip[1] >= 16 && ip[1] <= 31) || 
        (ip[0] === 192 && ip[1] === 168) ||
        ip[0] === 127 || ip[0] === 0 || ip[0] >= 224
      ) {
        ip = [getRandomByte(), getRandomByte(), getRandomByte(), getRandomByte()];
      }
    }
    return ip.join('.');
  }

  const btn = document.getElementById('runBtn');
  btn?.addEventListener('click', () => {
    const qty = parseInt((document.getElementById('qty') as HTMLInputElement).value) || 10;
    const type = (document.getElementById('class') as HTMLSelectElement).value;
    const listContainer = document.getElementById('v-list');
    
    let ipList = [];
    for(let i=0; i<qty; i++) {
      ipList.push(generateIP(type));
    }

    if(listContainer) {
      listContainer.innerHTML = ipList.map(ip => `<div>${ip}</div>`).join('');
    }
    document.getElementById('results').style.display = "block";
  });

  document.getElementById('copyBtn')?.addEventListener('click', function() {
    const list = document.getElementById('v-list').innerText;
    navigator.clipboard.writeText(list);
    this.innerText = "Copied!";
    setTimeout(() => this.innerText = "Copy List", 2000);
  });
</script>