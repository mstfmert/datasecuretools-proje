---
import Layout from '../../layouts/MainLayout.astro';
export const prerender = true;
---
<Layout title="Advanced Website Security Auditor | Vulnerability Scanner | DataSecureTools">
  <div style="max-width: 1300px; margin: 40px auto; padding: 0 20px; font-family: 'Inter', sans-serif; color: #0f172a;">
    
    <div style="width: 100%; height: 90px; background: #f8fafc; border: 1px dashed #cbd5e1; border-radius: 12px; margin-bottom: 30px; display: flex; align-items: center; justify-content: center; color: #94a3b8; font-size: 0.8rem;">
      ADVERTISEMENT - GOOGLE ADSENSE
    </div>

    <div style="display: grid; grid-template-columns: 1fr 340px; gap: 40px;">
      <main>
        <div style="background: #ffffff; border-radius: 32px; padding: 50px; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.03); border: 1px solid #f1f5f9;">
          <header style="margin-bottom: 40px;">
            <span style="background: #fff1f2; color: #e11d48; padding: 6px 14px; border-radius: 100px; font-size: 0.85rem; font-weight: 700;">CYBER INTELLIGENCE</span>
            <h1 style="font-size: 2.8rem; font-weight: 900; margin-top: 15px; letter-spacing: -1px;">Security Auditor</h1>
            <p style="color: #64748b; font-size: 1.2rem; margin-top: 10px;">Deep vulnerability scanning and infrastructure security audit for any web asset.</p>
          </header>

          <div style="background: #f8fafc; padding: 8px; border-radius: 20px; display: flex; border: 1px solid #e2e8f0; margin-bottom: 35px;">
            <input type="text" id="target" placeholder="Enter Website URL (e.g. https://google.com)" style="flex: 1; padding: 18px 25px; border: none; background: transparent; outline: none; font-size: 1.1rem;" />
            <button id="runBtn" style="background: #0f172a; color: white; padding: 0 35px; border-radius: 14px; border: none; font-weight: 700; cursor: pointer; transition: 0.3s;">SCAN TARGET</button>
          </div>

          <div id="results" style="display: none; animation: slideUp 0.6s ease-out;">
            <div id="threat-summary" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; margin-bottom: 40px;">
                </div>

            <div style="background: #0f172a; border-radius: 24px; padding: 40px; border: 1px solid #334155;">
              <span style="color: #64748b; font-size: 0.75rem; font-weight: 800; text-transform: uppercase;">Technical Security Report</span>
              <div id="v-findings" style="margin-top: 25px; display: flex; flex-direction: column; gap: 15px;"></div>
            </div>
          </div>
        </div>

        <article style="margin-top: 60px; line-height: 1.8; color: #475569;">
          <h2 style="color: #0f172a; font-size: 1.8rem; font-weight: 800;">Why Professional Security Audits are Vital?</h2>
          <p style="margin-top: 20px;">In an era of rising cyber threats, a <strong>Security Audit</strong> is your first line of defense. Our tool performs a multi-vector scan to identify common misconfigurations that attackers exploit. By analyzing <strong>SSL/TLS certificates</strong> and <strong>HTTP Security Headers</strong>, we provide a blueprint for hardening your web server against automated exploits and targeted attacks.</p>
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 30px; margin-top: 30px;">
            <div>
              <h3 style="color: #0f172a; font-size: 1.2rem; font-weight: 700;">Vulnerability Management</h3>
              <p style="font-size: 0.9rem;">Identify missing security layers like <strong>Content Security Policy (CSP)</strong> to prevent Cross-Site Scripting (XSS) and data injection attacks.</p>
            </div>
            <div>
              <h3 style="color: #0f172a; font-size: 1.2rem; font-weight: 700;">Infrastructure Hardening</h3>
              <p style="font-size: 0.9rem;">Audit your server's public identity. Hiding server banners and disabling insecure protocols significantly reduces the attack surface.</p>
            </div>
          </div>
        </article>
      </main>

      <aside>
        <div style="width: 100%; height: 600px; background: #f8fafc; border: 1px dashed #cbd5e1; border-radius: 24px; margin-bottom: 40px; display: flex; align-items: center; justify-content: center; color: #94a3b8;">
          ADSENSE SKYSCRAPER AD
        </div>

        <div style="background: #fff1f2; padding: 30px; border-radius: 32px;">
          <h3 style="font-size: 1.1rem; font-weight: 900; color: #0f172a; margin-bottom: 25px;">Defense Strategy</h3>
          <div style="display: flex; flex-direction: column; gap: 20px;">
            <div style="background: white; padding: 20px; border-radius: 18px;">
              <strong style="color: #e11d48; display: block; margin-bottom: 5px; font-size: 0.9rem;">Zero Trust Architecture</strong>
              <p style="font-size: 0.8rem; color: #64748b;">Never trust an internal network. Secure every endpoint as if it were exposed to the public internet.</p>
            </div>
            <div style="background: white; padding: 20px; border-radius: 18px;">
              <strong style="color: #10b981; display: block; margin-bottom: 5px; font-size: 0.9rem;">Automated Scanning</strong>
              <p style="font-size: 0.8rem; color: #64748b;">Schedule weekly security audits to detect new vulnerabilities introduced during code deployments.</p>
            </div>
          </div>
        </div>
      </aside>
    </div>
  </div>
</Layout>

<style> @keyframes slideUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } } </style>

<script>
  const btn = document.getElementById('runBtn');
  btn?.addEventListener('click', async () => {
    let url = (document.getElementById('target') as HTMLInputElement).value.trim();
    if(!url) return alert("Please enter a URL.");
    if(!url.startsWith('http')) url = 'https://' + url;

    btn.innerText = "SCANNING VULNERABILITIES...";
    btn.disabled = true;

    try {
      const proxyUrl = `https://api.allorigins.win/get?url=${encodeURIComponent(url)}`;
      const response = await fetch(proxyUrl);
      const json = await response.json();
      const headers = json.status.headers || {};
      
      const auditPoints = [
        { n: 'SSL/TLS Status', v: url.startsWith('https'), s: 'CRITICAL', d: 'Ensures data encryption in transit.' },
        { n: 'HSTS Header', v: !!headers['strict-transport-security'], s: 'HIGH', d: 'Prevents man-in-the-middle attacks.' },
        { n: 'CSP Header', v: !!headers['content-security-policy'], s: 'HIGH', d: 'Prevents XSS and code injection.' },
        { n: 'Clickjacking Protection', v: !!headers['x-frame-options'], s: 'MEDIUM', d: 'Prevents site from being embedded in frames.' },
        { n: 'MIME Sniffing', v: !!headers['x-content-type-options'], s: 'LOW', d: 'Forces the browser to follow MIME types.' }
      ];

      const issuesFound = auditPoints.filter(p => !p.v).length;
      
      const summaryDiv = document.getElementById('threat-summary');
      summaryDiv.innerHTML = `
        <div style="background:white; padding:25px; border-radius:24px; border-left:5px solid ${issuesFound > 0 ? '#ef4444' : '#10b981'}">
          <span style="font-size:0.7rem; font-weight:800; color:#94a3b8;">RISK LEVEL</span>
          <div style="font-weight:900; color:#0f172a; font-size:1.5rem; margin-top:5px;">${issuesFound > 2 ? 'EXTREME' : issuesFound > 0 ? 'MODERATE' : 'SECURE'}</div>
        </div>
        <div style="background:white; padding:25px; border-radius:24px; border-left:5px solid #3b82f6">
          <span style="font-size:0.7rem; font-weight:800; color:#94a3b8;">VULNERABILITIES</span>
          <div style="font-weight:900; color:#0f172a; font-size:1.5rem; margin-top:5px;">${issuesFound} Issues</div>
        </div>
      `;

      const findingsDiv = document.getElementById('v-findings');
      findingsDiv.innerHTML = auditPoints.map(p => `
        <div style="background:#1e293b; padding:25px; border-radius:20px; border:1px solid #334155; display:flex; justify-content:space-between; align-items:center;">
          <div>
            <div style="display:flex; align-items:center; gap:10px;">
              <strong style="color:#f8fafc; font-size:1.1rem;">${p.n}</strong>
              <span style="font-size:0.65rem; background:${p.v ? '#10b981' : '#e11d48'}; color:white; padding:3px 8px; border-radius:6px; font-weight:900;">${p.v ? 'PASSED' : p.s}</span>
            </div>
            <p style="color:#94a3b8; font-size:0.85rem; margin-top:8px;">${p.d}</p>
          </div>
          <div style="font-size:1.5rem;">${p.v ? '✅' : '🛡️'}</div>
        </div>
      `).join('');

      document.getElementById('results').style.display = "block";

    } catch (e) {
      alert("Scan Failed: Target server rejected the connection or URL is invalid.");
    } finally {
      btn.innerText = "SCAN TARGET";
      btn.disabled = false;
    }
  });
</script>