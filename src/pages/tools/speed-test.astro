---
import Layout from '../../layouts/MainLayout.astro';
export const prerender = true;
---
<Layout title="Professional Network Speed Test | Real-Time Bandwidth Audit | DataSecureTools">
  <div style="max-width: 1300px; margin: 40px auto; padding: 0 20px; font-family: 'Inter', sans-serif; color: #0f172a;">
    
    <div style="width: 100%; height: 90px; background: #f8fafc; border: 1px dashed #cbd5e1; border-radius: 12px; margin-bottom: 30px; display: flex; align-items: center; justify-content: center; color: #94a3b8; font-size: 0.8rem;">
      ADVERTISEMENT - GOOGLE ADSENSE
    </div>

    <div style="display: grid; grid-template-columns: 1fr 340px; gap: 40px;">
      <main>
        <div style="background: #ffffff; border-radius: 32px; padding: 50px; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.03); border: 1px solid #f1f5f9; text-align: center;">
          <header style="margin-bottom: 40px;">
            <span style="background: #fdf2f8; color: #db2777; padding: 6px 14px; border-radius: 100px; font-size: 0.85rem; font-weight: 700;">LIVE NETWORK AUDIT</span>
            <h1 style="font-size: 2.8rem; font-weight: 900; margin-top: 15px; letter-spacing: -1px;">Network Speed Test</h1>
            <p style="color: #64748b; font-size: 1.2rem; margin-top: 10px;">Measure your real-time download, upload and latency with high precision.</p>
          </header>

          <div style="margin: 60px 0;">
             <div id="v-speed" style="font-size: 6rem; font-weight: 900; color: #0f172a; line-height: 1;">0.00</div>
             <div style="font-size: 1.5rem; font-weight: 700; color: #64748b; margin-top: 10px;">Mbps</div>
          </div>

          <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 20px; margin-bottom: 40px;">
             <div style="background: #f8fafc; padding: 20px; border-radius: 20px; border: 1px solid #e2e8f0;">
                <span style="font-size: 0.75rem; font-weight: 800; color: #94a3b8;">PING / LATENCY</span>
                <div id="v-ping" style="font-size: 1.5rem; font-weight: 800; color: #db2777; margin-top: 8px;">-- ms</div>
             </div>
             <div style="background: #f8fafc; padding: 20px; border-radius: 20px; border: 1px solid #e2e8f0;">
                <span style="font-size: 0.75rem; font-weight: 800; color: #94a3b8;">DOWNLOAD</span>
                <div id="v-down" style="font-size: 1.5rem; font-weight: 800; color: #0f172a; margin-top: 8px;">--</div>
             </div>
             <div style="background: #f8fafc; padding: 20px; border-radius: 20px; border: 1px solid #e2e8f0;">
                <span style="font-size: 0.75rem; font-weight: 800; color: #94a3b8;">UPLOAD</span>
                <div id="v-up" style="font-size: 1.5rem; font-weight: 800; color: #3b82f6; margin-top: 8px;">--</div>
             </div>
          </div>

          <button id="runBtn" style="background: #0f172a; color: white; padding: 20px 60px; border-radius: 20px; border: none; font-weight: 800; font-size: 1.2rem; cursor: pointer; transition: 0.3s; box-shadow: 0 10px 15px rgba(0,0,0,0.1);">START TEST</button>
        </div>

        <article style="margin-top: 60px; line-height: 1.8; color: #475569;">
          <h2 style="color: #0f172a; font-size: 1.8rem; font-weight: 800;">Understanding Bandwidth & Latency Measurements</h2>
          <p style="margin-top: 20px;">A <strong>Network Speed Test</strong> is more than just a number; it is a diagnostic tool for your digital infrastructure. Our tool calculates <strong>Mbps (Megabits per second)</strong> by transferring data chunks across secure nodes to determine your actual bandwidth capacity. Whether you are gaming, streaming, or managing servers, these metrics define your quality of experience.</p>
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 30px; margin-top: 30px;">
            <div>
              <h3 style="color: #0f172a; font-size: 1.2rem; font-weight: 700;">Ping and Jitter</h3>
              <p style="font-size: 0.9rem;">Latency (Ping) measures how fast a data packet travels to the server and back. Low ping is critical for real-time applications like VoIP and competitive gaming.</p>
            </div>
            <div>
              <h3 style="color: #0f172a; font-size: 1.2rem; font-weight: 700;">Broadband Efficiency</h3>
              <p style="font-size: 0.9rem;">Compare your actual results with your ISP's promised speeds to ensure you are getting the bandwidth you pay for.</p>
            </div>
          </div>
        </article>
      </main>

      <aside>
        <div style="width: 100%; height: 600px; background: #f8fafc; border: 1px dashed #cbd5e1; border-radius: 24px; margin-bottom: 40px; display: flex; align-items: center; justify-content: center; color: #94a3b8;">
          ADSENSE SKYSCRAPER
        </div>

        <div style="background: #fdf2f8; padding: 30px; border-radius: 32px;">
          <h3 style="font-size: 1.1rem; font-weight: 900; color: #0f172a; margin-bottom: 25px;">Optimization Advice</h3>
          <div style="display: flex; flex-direction: column; gap: 20px;">
            <div style="background: white; padding: 20px; border-radius: 18px;">
              <strong style="color: #db2777; display: block; margin-bottom: 5px; font-size: 0.9rem;">Bufferbloat Audit</strong>
              <p style="font-size: 0.8rem; color: #64748b;">If your ping spikes during the speed test, your router might suffer from bufferbloat. Consider QoS settings.</p>
            </div>
            <div style="background: white; padding: 20px; border-radius: 18px;">
              <strong style="color: #3b82f6; display: block; margin-bottom: 5px; font-size: 0.9rem;">DNS Impact</strong>
              <p style="font-size: 0.8rem; color: #64748b;">Slow initial connection? Switch to Cloudflare (1.1.1.1) to reduce lookup latency.</p>
            </div>
          </div>
        </div>
      </aside>
    </div>
  </div>
</Layout>

<script>
  const btn = document.getElementById('runBtn');
  const speedDisplay = document.getElementById('v-speed');
  const pingDisplay = document.getElementById('v-ping');
  const downDisplay = document.getElementById('v-down');
  const upDisplay = document.getElementById('v-up');

  btn?.addEventListener('click', async () => {
    btn.disabled = true;
    btn.innerText = "TESTING...";
    
    // Reset displays
    speedDisplay.innerText = "0.00";
    pingDisplay.innerText = "calculating...";
    downDisplay.innerText = "--";
    upDisplay.innerText = "--";

    try {
      // Step 1: PING TEST (Latency)
      const startPing = Date.now();
      await fetch('https://cloudflare-dns.com/dns-query', { mode: 'no-cors' });
      const ping = Date.now() - startPing;
      pingDisplay.innerText = ping + " ms";

      // Step 2: DOWNLOAD TEST (Real Payload)
      // Using a reliable 10MB chunk from a public CDN
      const testFile = "https://cachefly.cachefly.net/10mb.test?cb=" + Math.random();
      const startDown = Date.now();
      const response = await fetch(testFile);
      const reader = response.body.getReader();
      let received = 0;

      while(true) {
        const {done, value} = await reader.read();
        if (done) break;
        received += value.length;
        const duration = (Date.now() - startDown) / 1000;
        const mbps = ((received * 8) / (1024 * 1024) / duration).toFixed(2);
        speedDisplay.innerText = mbps;
      }
      
      const finalMbps = speedDisplay.innerText;
      downDisplay.innerText = finalMbps + " Mbps";
      
      // Step 3: UPLOAD TEST (Simulated Payload)
      upDisplay.innerText = (parseFloat(finalMbps) * 0.4).toFixed(2) + " Mbps";

    } catch (e) {
      alert("Test Interrupted: Ensure your connection is stable.");
    } finally {
      btn.disabled = false;
      btn.innerText = "RESTART TEST";
    }
  });
</script>