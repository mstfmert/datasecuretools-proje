export const prerender = true;
---
// src/pages/tools/subnet-calculator.astro
import Layout from '../../layouts/MainLayout.astro';
---

<Layout title="Subnet Calculator - DataSecureTools">
  <main class="tool-container">
    <section class="hero-section">
      <h1>Subnet Calculator</h1>
      <p>Calculate network range, broadcast address, and usable hosts for any IPv4 CIDR.</p>
    </section>

    <div class="tool-card">
      <div class="input-row">
        <div class="input-group">
          <label>IP Address</label>
          <input type="text" id="ipInput" placeholder="192.168.1.1" value="192.168.1.0" />
        </div>
        <div class="input-group">
          <label>Subnet Mask (CIDR)</label>
          <select id="cidrSelect">
            {Array.from({ length: 32 }, (_, i) => i + 1).reverse().map(n => (
              <option value={n} selected={n === 24}>/{n}</option>
            ))}
          </select>
        </div>
      </div>

      <button id="calcBtn" class="calc-button">Calculate Network</button>

      <div id="resultArea" class="result-display hidden">
        <div class="result-card main-res">
          <span>Network Address</span>
          <strong id="resNetwork">-</strong>
        </div>
        
        <div class="res-grid">
          <div class="result-card">
            <span>Usable Host Range</span>
            <strong id="resRange">-</strong>
          </div>
          <div class="result-card">
            <span>Broadcast Address</span>
            <strong id="resBroadcast">-</strong>
          </div>
          <div class="result-card">
            <span>Total Hosts</span>
            <strong id="resTotal">-</strong>
          </div>
          <div class="result-card">
            <span>Subnet Mask</span>
            <strong id="resMask">-</strong>
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>

<script>
  function ipToInt(ip: string) {
    return ip.split('.').reduce((res, octet) => (res << 8) + parseInt(octet, 10), 0) >>> 0;
  }

  function intToIp(int: number) {
    return [(int >>> 24) & 0xFF, (int >>> 16) & 0xFF, (int >>> 8) & 0xFF, int & 0xFF].join('.');
  }

  function calculateSubnet() {
    const ipStr = (document.getElementById('ipInput') as HTMLInputElement).value;
    const cidr = parseInt((document.getElementById('cidrSelect') as HTMLSelectElement).value);
    
    const ipInt = ipToInt(ipStr);
    const maskInt = (0xFFFFFFFF << (32 - cidr)) >>> 0;
    const networkInt = (ipInt & maskInt) >>> 0;
    const broadcastInt = (networkInt | ~maskInt) >>> 0;
    
    const totalHosts = Math.pow(2, 32 - cidr);
    const usableHosts = cidr <= 30 ? totalHosts - 2 : (cidr === 31 ? 2 : 1);

    document.getElementById('resNetwork')!.textContent = intToIp(networkInt);
    document.getElementById('resMask')!.textContent = intToIp(maskInt);
    document.getElementById('resBroadcast')!.textContent = intToIp(broadcastInt);
    document.getElementById('resTotal')!.textContent = usableHosts.toLocaleString();
    
    const rangeStart = intToIp(networkInt + (cidr <= 30 ? 1 : 0));
    const rangeEnd = intToIp(broadcastInt - (cidr <= 30 ? 1 : 0));
    document.getElementById('resRange')!.textContent = `${rangeStart} - ${rangeEnd}`;

    document.getElementById('resultArea')?.classList.remove('hidden');
  }

  document.getElementById('calcBtn')?.addEventListener('click', calculateSubnet);
</script>

<style>
  .tool-container { max-width: 800px; margin: 60px auto; padding: 0 20px; font-family: 'Inter', sans-serif; }
  .hero-section { text-align: center; margin-bottom: 40px; }
  .hero-section h1 { font-size: 2.5rem; font-weight: 800; color: #111; }
  
  .tool-card { background: #fff; border: 1px solid #f3f4f6; border-radius: 16px; padding: 40px; box-shadow: 0 10px 25px rgba(0,0,0,0.05); }

  .input-row { display: flex; gap: 20px; margin-bottom: 25px; }
  .input-group { flex: 1; display: flex; flex-direction: column; gap: 8px; }
  .input-group label { font-size: 0.8rem; font-weight: 700; color: #6b7280; text-transform: uppercase; }
  .input-group input, .input-group select { padding: 12px; border: 1px solid #e5e7eb; border-radius: 8px; font-size: 1rem; outline: none; }

  .calc-button { width: 100%; background: #2563eb; color: #fff; border: none; padding: 15px; border-radius: 10px; font-weight: 700; cursor: pointer; transition: background 0.2s; margin-bottom: 30px; }
  .calc-button:hover { background: #1d4ed8; }

  .result-display { animation: fadeIn 0.3s ease-out; }
  .result-card { background: #f9fafb; padding: 20px; border-radius: 12px; border: 1px solid #f3f4f6; margin-bottom: 20px; }
  .main-res { border-left: 4px solid #2563eb; }
  .result-card span { display: block; font-size: 0.75rem; font-weight: 700; color: #9ca3af; text-transform: uppercase; margin-bottom: 5px; }
  .result-card strong { font-size: 1.2rem; color: #111827; font-family: 'Monaco', monospace; }

  .res-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
  
  .hidden { display: none; }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

  @media (max-width: 600px) { .input-row, .res-grid { grid-template-columns: 1fr; flex-direction: column; } }
</style>

