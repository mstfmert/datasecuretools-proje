---
import Layout from '../../layouts/MainLayout.astro';
export const prerender = true;
---
<Layout title="Advanced VPN Leak Test | WebRTC & DNS Privacy Audit | DataSecureTools">
  <div style="max-width: 1200px; margin: 40px auto; padding: 0 20px; font-family: 'Inter', sans-serif; color: #0f172a;">
    
    <div style="width: 100%; height: 90px; background: #ffffff; border: 1px dashed #cbd5e1; border-radius: 12px; margin-bottom: 30px; display: flex; align-items: center; justify-content: center; color: #94a3b8; font-size: 0.8rem; letter-spacing: 1px;">
      ADVERTISEMENT - GOOGLE ADSENSE
    </div>

    <div style="display: grid; grid-template-columns: 1fr 340px; gap: 40px; align-items: start;">
      
      <main>
        <div style="background: #ffffff; border-radius: 40px; padding: 60px; box-shadow: 0 10px 30px rgba(0,0,0,0.02); border: 1px solid #f1f5f9;">
          <header style="margin-bottom: 40px;">
            <span style="background: #f1f5f9; color: #475569; padding: 6px 14px; border-radius: 100px; font-size: 0.75rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.5px;">Privacy Integrity</span>
            <h1 style="font-size: 3rem; font-weight: 900; margin-top: 15px; letter-spacing: -1.5px; color: #0f172a;">VPN Leak Detector</h1>
            <p style="color: #64748b; font-size: 1.15rem; margin-top: 15px; line-height: 1.6;">Audit your network stack for WebRTC and DNS leaks that expose your identity.</p>
          </header>

          <div style="background: #f8fafc; padding: 30px; border-radius: 24px; border: 1px solid #e2e8f0; text-align: center; margin-bottom: 35px;">
            <button id="runBtn" style="background: #0f172a; color: white; padding: 18px 50px; border-radius: 18px; border: none; font-weight: 800; font-size: 1rem; cursor: pointer; transition: 0.3s; text-transform: uppercase;">RUN LEAK AUDIT</button>
            <p style="margin-top: 15px; font-size: 0.85rem; color: #94a3b8;">Scans browser metadata and RTC endpoints locally.</p>
          </div>

          <div id="results" style="display: none; animation: slideUp 0.6s ease-out;">
              <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 40px;">
                  <div style="background: #ffffff; padding: 30px; border-radius: 24px; border: 1px solid #f1f5f9; text-align: center;">
                      <span style="font-size: 0.7rem; font-weight: 800; color: #94a3b8; text-transform: uppercase;">WebRTC Status</span>
                      <div id="v-webrtc" style="font-size: 1.8rem; font-weight: 900; color: #10b981; margin-top: 8px;">SECURED</div>
                  </div>
                  <div style="background: #ffffff; padding: 30px; border-radius: 24px; border: 1px solid #f1f5f9; text-align: center;">
                      <span style="font-size: 0.7rem; font-weight: 800; color: #94a3b8; text-transform: uppercase;">ISP Connection</span>
                      <div id="v-isp" style="font-size: 1.3rem; font-weight: 800; color: #0f172a; margin-top: 8px;">Detecting...</div>
                  </div>
              </div>
          </div>
        </div>

        <div style="margin-top: 60px;">
            <h2 style="font-size: 1.8rem; font-weight: 900; color: #0f172a; margin-bottom: 25px; letter-spacing: -0.5px;">The Science of De-anonymization Leaks</h2>
            <p style="color: #475569; line-height: 1.8; font-size: 1.05rem; margin-bottom: 40px;">A <strong>VPN Leak</strong> is a technical failure where your browser sends data outside the encrypted tunnel. <strong>WebRTC leaks</strong> are the most common culprit, allowing websites to bypass your VPN and see your true local and public IP addresses. Our <strong>Leak Detector</strong> performs a deep audit of your network stack to ensure your digital footprint remains fully encrypted.</p>
            
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 40px;">
                <div>
                    <h3 style="font-size: 1.15rem; font-weight: 800; color: #0f172a; margin-bottom: 15px;">DNS Leak Protection</h3>
                    <p style="font-size: 0.95rem; color: #64748b; line-height: 1.7;">If your DNS queries go to your ISP instead of the VPN, your entire browsing history is being logged. We verify the DNS authority to ensure maximum privacy.</p>
                </div>
                <div>
                    <h3 style="font-size: 1.15rem; font-weight: 800; color: #0f172a; margin-bottom: 15px;">IPv6 Security Audit</h3>
                    <p style="font-size: 0.95rem; color: #64748b; line-height: 1.7;">Many systems leak identity through an unencrypted IPv6 stack. Our engine checks for dual-stack leaks that could compromise your anonymity.</p>
                </div>
            </div>
        </div>
      </main>

      <aside>
        <div style="width: 100%; height: 600px; background: #ffffff; border: 1px dashed #cbd5e1; border-radius: 24px; margin-bottom: 40px; display: flex; align-items: center; justify-content: center; color: #94a3b8; font-size: 0.8rem; text-align: center; padding: 20px;">
          ADSENSE SKYSCRAPER
        </div>

        <div style="background: #f8fafc; border-radius: 32px; padding: 30px; border: 1px solid #f1f5f9;">
            <h3 style="font-size: 1rem; font-weight: 900; color: #0f172a; margin-bottom: 25px;">Strategic Advice</h3>
            
            <div style="background: #ffffff; padding: 25px; border-radius: 20px; box-shadow: 0 4px 6px rgba(0,0,0,0.01); margin-bottom: 20px; border: 1px solid #f1f5f9;">
                <strong style="color: #ef4444; display: block; margin-bottom: 10px; font-size: 0.85rem; font-weight: 800; text-transform: uppercase;">Kill Switch</strong>
                <p style="font-size: 0.8rem; color: #64748b; line-height: 1.6;">Always enable your VPN's Kill Switch to prevent accidental IP exposure if the connection drops.</p>
            </div>

            <div style="background: #ffffff; padding: 25px; border-radius: 20px; box-shadow: 0 4px 6px rgba(0,0,0,0.01); border: 1px solid #f1f5f9;">
                <strong style="color: #10b981; display: block; margin-bottom: 10px; font-size: 0.85rem; font-weight: 800; text-transform: uppercase;">Disable WebRTC</strong>
                <p style="font-size: 0.8rem; color: #64748b; line-height: 1.6;">For maximum stealth, use browser extensions to fully disable WebRTC communication in your browser.</p>
            </div>
        </div>
      </aside>

    </div>
  </div>
</Layout>

<style>
  @keyframes slideUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
  #runBtn:hover { background: #1e293b; transform: translateY(-2px); }
</style>

<script>
  const btn = document.getElementById('runBtn');
  
  async function checkWebRTC() {
    return new Promise((resolve) => {
      const ips = [];
      const pc = new RTCPeerConnection({ iceServers: [{ urls: "stun:stun.l.google.com:19302" }] });
      pc.createDataChannel("");
      pc.onicecandidate = (e) => {
        if (!e.candidate) { pc.close(); resolve(ips); return; }
        const ip = /([0-9]{1,3}(\.[0-9]{1,3}){3}|([a-f0-9]{1,4}(:[a-f0-9]{1,4}){7}))/.exec(e.candidate.candidate);
        if (ip && !ips.includes(ip[1])) ips.push(ip[1]);
      };
      pc.createOffer().then(sdp => pc.setLocalDescription(sdp));
      setTimeout(() => { pc.close(); resolve(ips); }, 1500);
    });
  }

  btn?.addEventListener('click', async () => {
    btn.innerText = "AUDITING...";
    btn.disabled = true;

    try {
      const webrtcIps = await checkWebRTC() as string[];
      const ipResp = await fetch('https://ipapi.co/json/');
      const data = await ipResp.json();

      const webrtcStatus = document.getElementById('v-webrtc');
      const isLeaking = webrtcIps.length > 1;
      
      webrtcStatus.innerText = isLeaking ? 'LEAK DETECTED' : 'SECURED';
      webrtcStatus.style.color = isLeaking ? '#ef4444' : '#10b981';
      document.getElementById('v-isp').innerText = data.org || 'Detected';

      document.getElementById('results').style.display = "block";
    } catch (e) {
      alert("Audit Failed.");
    } finally {
      btn.innerText = "RUN LEAK AUDIT";
      btn.disabled = false;
    }
  });
</script>